#colores utiles

gradient_text() {
  local text="$1"
  local start=(255 0 180)
  local end=(0 200 255)
  local len=${#text}

  for ((i=0;i<len;i++)); do
    r=$(( start[1] + (end[1]-start[1]) * i / (len-1) ))
    g=$(( start[2] + (end[2]-start[2]) * i / (len-1) ))
    b=$(( start[3] + (end[3]-start[3]) * i / (len-1) ))

    char="${text[$((i+1))]}"
    printf "\033[1;38;2;%d;%d;%dm%s" "$r" "$g" "$b" "$char"
  done

  printf "\033[0m"
}

gradient_shift() {
  local text="$1"
  local shift=$(( $(date +%s%N) / 10000000 % 255 ))
  local len=${#text}

  for ((i=0;i<len;i++)); do
    r=$(( (i*20 + shift) % 255 ))
    g=$(( (i*40 + shift) % 255 ))
    b=$(( (i*60 + shift) % 255 ))

    char="${text[$((i+1))]}"
    printf "\033[1;38;2;%d;%d;%dm%s" "$r" "$g" "$b" "$char"
  done

  printf "\033[0m"
}

gradient_glow() {
  local text="$1"

  local colors=(
    "255,100,200"
    "200,120,255"
    "150,150,255"
  )

  local out=""
  local i=1

  for ((c=1; c<=${#text}; c++)); do
    local char="${text[$c]}"
    local color="${colors[$i]}"
    [[ -z "$color" ]] && color="${colors[-1]}"

    out+="%F{$color}$char"
    ((i++))
  done

  out+="%f"

  p10k segment -t "$out"
}



    

