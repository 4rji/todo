mktem() {
    case "$(uname -s)" in
        Darwin)
            ramdisk_path="/Volumes/RAMDisk"

            if [ ! -d "$ramdisk_path" ]; then
                echo "Montando RAMDisk..."
                diskutil erasevolume HFS+ RAMDisk \
                    "$(hdiutil attach -nomount ram://$((4 * 1024 * 1024 * 1024 / 512)))" > /dev/null
            fi

            base="$ramdisk_path"
            ;;
        Linux)
            base="/dev/shm"
            ;;
        *)
            echo "Sistema no soportado: $(uname -s)" >&2
            return 1
            ;;
    esac

    if [ -n "$1" ]; then
        new_dir=$(mktemp -d "$base/tmp.$1.XXXXXX")
    else
        new_dir=$(mktemp -d "$base/tmp.XXXXXX")
    fi

    echo "Directorio creado en: $new_dir"
    cd "$new_dir" || return
    echo "Cambiado al directorio: $PWD"
}


