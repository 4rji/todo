loop() {
    echo "Enter the commands to execute in the loop. Type 'done' to finish."
    
    local commands=()
    
    while true; do
        read "cmd?Command: "
        if [[ "$cmd" == "done" ]]; then
            break
        fi
        commands+=("$cmd")
    done
    
    while true; do
        for cmd in "${commands[@]}"; do
            eval "$cmd"
        done
    done
}



# Cliente HTTP mínimo en zsh que hace GET vía TCP usando /dev/tcp, similar a wget -qO- pero sin TLS.
#USO:
# wgetf  http://192.168.44.27:8000/a.py | tee a.py 
# wgetf  http://192.168.44.27:8000/a.py > a.py
wgetf () {
    bash -c '
    rest="${1#*://}"
    hp="${rest%%/*}"
    path="/${rest#*/}"
    h="$hp"; port=80
    [[ "$hp" == *:* ]] && { h="${hp%%:*}"; port="${hp##*:}"; }

    exec 3<>"/dev/tcp/$h/$port" || exit 1
    printf "GET %s HTTP/1.1\r\nHost: %s\r\nConnection: close\r\n\r\n" "$path" "$hp" >&3

    # skip headers (stop ONLY at CR line)
    while IFS= read -r l <&3; do
      [[ "$l" == $'\''\r'\'' ]] && break
    done

    cat <&3
  ' _ "$1"
}



#Muestra el ultimo comando con colores con bat 
function coll() {
    # Obtener el último comando del historial excluyendo números de línea y espacios iniciales
    local cmd=$(fc -ln -1 | sed 's/^[[:space:]]*//')

    # Crear un archivo temporal para guardar el comando
    local temp_file=$(mktemp)

    # Escribir el comando en el archivo temporal
    echo $cmd > "$temp_file"

    # Ejecutar el comando y usar 'tee' para duplicar la salida y 'batcat' para visualizarla
    eval $cmd | tee "$temp_file" | /bin/batcat --paging=never --pager=none --style=plain -l rb
}

