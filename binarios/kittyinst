#!/usr/bin/env bash
set -euo pipefail

green='\033[0;32m'
yellow='\033[0;33m'
red='\033[0;31m'
nocolor='\033[0m'

msg() { printf '%b%s%b\n' "$green" "$1" "$nocolor"; }
info() { printf '%b%s%b\n' "$yellow" "$1" "$nocolor"; }
die() {
  printf '%b%s%b\n' "$red" "$1" "$nocolor" >&2
  exit 1
}

kitty_instalado() {
  command -v kitty >/dev/null 2>&1 ||
    [[ -d /Applications/kitty.app ]] ||
    [[ -d "$HOME/Applications/kitty.app" ]]
}

instalar_kitty() {
  if kitty_instalado; then
    msg "kitty ya está instalado"
    return
  fi

  case "$(uname -s)" in
    Darwin)
      command -v brew >/dev/null 2>&1 || die "Homebrew no está instalado. Instalá brew y vuelve a correr kittyinst."
      info "Instalando kitty en macOS con Homebrew..."
      brew install --cask kitty
      ;;
    Linux)
      if command -v apt-get >/dev/null 2>&1; then
        info "Instalando kitty con apt..."
        sudo apt-get update
        sudo apt-get install -y kitty
      elif command -v pacman >/dev/null 2>&1; then
        info "Instalando kitty con pacman..."
        sudo pacman -S --noconfirm kitty
      elif command -v dnf >/dev/null 2>&1; then
        info "Instalando kitty con dnf..."
        sudo dnf install -y kitty
      elif command -v yum >/dev/null 2>&1; then
        info "Instalando kitty con yum..."
        sudo yum install -y kitty
      else
        die "Linux no soportado. Necesito apt, pacman, dnf o yum."
      fi
      ;;
    *)
      die "Sistema no soportado: $(uname -s)"
      ;;
  esac
}

descargar() {
  local url="$1"
  local destino="$2"

  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$url" -o "$destino"
  elif command -v wget >/dev/null 2>&1; then
    wget -q -O "$destino" "$url"
  else
    die "Necesito curl o wget para descargar la configuración."
  fi
}

instalar_kitty

kitty_dir="$HOME/.config/kitty"
mkdir -p "$kitty_dir"
msg "Directorio de kitty listo: $kitty_dir"

while IFS='|' read -r file url; do
  [[ -n "$file" ]] || continue

  path="$kitty_dir/$file"
  if descargar "$url" "$path"; then
    info "Archivo actualizado: $path"
  else
    die "Error al descargar: $file"
  fi
done <<'EOF'
kitty.conf|https://raw.githubusercontent.com/4rji/dotfiles/main/kitty/kitty.conf
color.ini|https://raw.githubusercontent.com/4rji/dotfiles/main/kitty/color.ini
aura-theme.conf|https://raw.githubusercontent.com/4rji/dotfiles/refs/heads/main/kitty/aura-theme.conf
EOF

msg "Instalación exitosa."

printf '\n\033[1;37m_________________________________________________________\033[0m\n\n'
echo "Para editar el tema kitten theme"
