#!/usr/bin/env bash
set -euo pipefail

STATE_DIR="${XDG_RUNTIME_DIR:-/tmp}/keepawake"
PID_FILE="$STATE_DIR/inhibit.pid"
COOKIE_FILE="$STATE_DIR/screensaver.cookie"

mkdir -p "$STATE_DIR"

qdbus_cmd() {
  if command -v qdbus6 >/dev/null 2>&1; then
    qdbus6 "$@"
  elif command -v qdbus-qt6 >/dev/null 2>&1; then
    qdbus-qt6 "$@"
  elif command -v qdbus >/dev/null 2>&1; then
    qdbus "$@"
  else
    return 1
  fi
}

is_running() {
  [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null
}

apply_disable() {
  if is_running; then
    echo "Ya activo (PID $(cat "$PID_FILE")). Usá '$0 d' para restaurar."
    return 0
  fi

  systemd-inhibit \
    --what=idle:handle-lid-switch \
    --who=dor \
    --why="trabajo activo" \
    --mode=block \
    sleep infinity >/dev/null 2>&1 &
  echo $! > "$PID_FILE"

  if cookie=$(qdbus_cmd org.freedesktop.ScreenSaver /ScreenSaver org.freedesktop.ScreenSaver.Inhibit "dor" "trabajo activo" 2>/dev/null); then
    printf '%s\n' "$cookie" > "$COOKIE_FILE"
  fi

  echo "Despierto. Idle bloqueado, lid ignorado, screensaver inhibido."
  echo "Suspensión manual ('$0 dd' o 'systemctl suspend') sigue funcionando."
}

restore_state() {
  local restored=0

  if [ -f "$PID_FILE" ]; then
    local pid
    pid=$(cat "$PID_FILE")
    if kill -0 "$pid" 2>/dev/null; then
      kill "$pid" 2>/dev/null || true
      restored=1
    fi
    rm -f "$PID_FILE"
  fi

  if [ -f "$COOKIE_FILE" ]; then
    local cookie
    cookie=$(cat "$COOKIE_FILE")
    qdbus_cmd org.freedesktop.ScreenSaver /ScreenSaver org.freedesktop.ScreenSaver.UnInhibit "$cookie" 2>/dev/null || true
    rm -f "$COOKIE_FILE"
    restored=1
  fi

  if [ "$restored" -eq 1 ]; then
    echo "Restaurado. Sistema vuelve a comportamiento normal."
  else
    echo "No había inhibidor activo."
  fi
}

suspend_now() {
  restore_state >/dev/null 2>&1 || true
  exec systemctl suspend
}

status() {
  if is_running; then
    echo "Estado: ACTIVO (PID $(cat "$PID_FILE"))"
    echo
    systemd-inhibit --list 2>/dev/null | awk 'NR==1 || /dor/'
  else
    echo "Estado: inactivo"
  fi
}

case "${1:-}" in
  a)  apply_disable ;;
  d)  restore_state ;;
  dd) suspend_now ;;
  s|status) status ;;
  *)
    cat <<EOF
Uso:
  $0 a       # mantiene despierto (bloquea idle/lid/screensaver)
  $0 d       # restaura comportamiento normal
  $0 dd      # suspende ahora (systemctl suspend)
  $0 s       # muestra estado
EOF
    exit 1
    ;;
esac
