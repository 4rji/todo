#!/usr/bin/env bash
set -euo pipefail

separator() { printf '\e[34m_________________________________________________________\e[0m\n'; }

show_help_and_confirm() {
    local ip=${1:-<IP>}
    printf '\e[32mThe command this script executes is:\e[0m\n\n'
    printf '\e[33m1) - sudo nmap %s -p- --open -sS --min-rate 5000 -v -n -oG allPorts\e[0m\n' "$ip"
    printf '\e[35m2) - sudo nmap %s -p- --open -sS --min-rate 5000 -v -n -Pn -oG allPorts\e[0m\n\n' "$ip"
    read -n1 -p $'\e[36mPress Enter to continue or "c" to exit.\e[0m '
    echo; separator; echo
    [[ "${REPLY,,}" == "c" ]] && { printf '\e[31mExiting.\e[0m\n'; exit 0; }
}

command -v nmap >/dev/null || { printf '\e[31mnmap no instalado\e[0m\n'; exit 1; }

echo; separator; echo

if [[ "${1:-}" == "-h" ]]; then
    show_help_and_confirm
    exit 0
fi

if [[ -z "${1:-}" ]]; then
    printf '\e[31mYou must specify the IP as a script argument.\e[0m\n'
    exit 1
fi

ip=$1
[[ "$ip" =~ ^[A-Za-z0-9.:-]+$ ]] || { printf '\e[31mIP/host invalido\e[0m\n'; exit 1; }

printf '\n\e[32mSelect the type of scan you want to use:\e[0m\n\n'
printf '\e[33m1. Run scan without Pn\e[0m\n'
printf '\e[35m2. Run scan with Pn\e[0m\n\n'
separator
echo
printf '\e[32mThe command to execute is:\e[0m\n'
printf '\e[33msudo nmap %s -p- --open -sS --min-rate 5000 -v -n -oG allPorts\e[0m\n\n' "$ip"
separator
echo

read -n1 -p $'\e[36mChoose (1 or 2):\e[0m ' choice
echo

case $choice in
    1) printf '\e[32mRunning scan without Pn...\e[0m\n'
       sudo nmap "$ip" -p- --open -sS --min-rate 5000 -v -n -oG allPorts ;;
    2) printf '\e[33mRunning scan with Pn...\e[0m\n'
       sudo nmap "$ip" -p- --open -sS --min-rate 5000 -v -n -Pn -oG allPorts ;;
    *) printf '\e[31mInvalid option. Choose 1 or 2.\e[0m\n'; exit 1 ;;
esac
