#!/usr/bin/env bash
set -euo pipefail

PIDFILE="/tmp/cloudflared_tunnel.pid"
LOGFILE="/tmp/cloudflared_tunnel.log"

# URLs
URL_DEB_AMD="https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-amd64.deb"
URL_RPM_AMD="https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-x86_64.rpm"
URL_BIN_AMD="https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-amd64"
URL_BIN_ARM="https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-arm64"

# Helpers
is_running_pid() {
  local pid="$1"
  [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null
}

find_cloudflared_pid() {
  if [ -f "$PIDFILE" ]; then
    pid="$(cat "$PIDFILE" 2>/dev/null || true)"
    if is_running_pid "$pid"; then
      echo "$pid"
      return 0
    else
      rm -f "$PIDFILE" 2>/dev/null || true
    fi
  fi
  pid="$(pgrep -u "$(id -u)" -f "cloudflared tunnel run" | head -n1 || true)"
  if [ -n "$pid" ]; then
    echo "$pid"
    return 0
  fi
  pid="$(pgrep -u "$(id -u)" -f "cloudflared" | head -n1 || true)"
  if [ -n "$pid" ]; then
    echo "$pid"
    return 0
  fi
  return 1
}

show_configured_tunnels() {
  echo ""
  echo -e "\033[1;36m-- Configured tunnels --\033[0m"
  echo -e "\033[1;32m  http.4rji.com    ->  http://127.0.0.1:80  \033[0m"
  echo -e "\033[1;33m  3000.4rji.com    ->  http://localhost:3000  \033[0m"
  echo -e "\033[1;35m  8080.4rji.com    ->  http://localhost:8080  \033[0m"
  echo -e "\033[1;35m  9000.4rji.com    ->  http://localhost:9000  \033[0m"
  echo -e "\033[1;36m  smb.4rji.com     ->  smb://127.0.0.1:445  \033[0m"
  echo -e "\033[1;36m  sssh.4rji.com    ->  ssh  \033[0m"
  echo ""
}

install_cloudflared_wget() {
  echo ""
  echo -e "\033[1;37m Select version to download (wget only):\033[0m"
  echo "  1) amd64 .deb   ($URL_DEB_AMD)"
  echo "  2) amd64 .rpm   ($URL_RPM_AMD)"
  echo "  3) amd64 binary ($URL_BIN_AMD)"
  echo "  4) arm64 binary ($URL_BIN_ARM)"
  echo ""
  read -n1 -rp "Option: " opt
  echo ""

  case "$opt" in
    1) wget -O cloudflared-linux-amd64.deb "$URL_DEB_AMD" ;;
    2) wget -O cloudflared-linux-x86_64.rpm "$URL_RPM_AMD" ;;
    3) wget -O cloudflared-linux-amd64 "$URL_BIN_AMD" ;;
    4) wget -O cloudflared-linux-arm64 "$URL_BIN_ARM" ;;
    *) echo -e "\033[1;31m Invalid option\033[0m" ;;
  esac
  echo ""
}

install_cloudflared_os() {
  echo ""
  echo "Select OS to install Cloudflared:"
  echo "1) Debian/Ubuntu"
  echo "2) macOS (brew)"
  echo "3) Windows"
  echo "4) Docker"
  read -rp "Option: " opt

  case "$opt" in
    1)
      sudo mkdir -p --mode=0755 /usr/share/keyrings
      curl -fsSL https://pkg.cloudflare.com/cloudflare-public-v2.gpg \
        | sudo tee /usr/share/keyrings/cloudflare-public-v2.gpg >/dev/null

      echo 'deb [signed-by=/usr/share/keyrings/cloudflare-public-v2.gpg] https://pkg.cloudflare.com/cloudflared any main' \
        | sudo tee /etc/apt/sources.list.d/cloudflared.list

      sudo apt-get update
      sudo apt-get install -y cloudflared
      ;;
    2)
      brew install cloudflared
      ;;
    3)
      echo "Download:"
      echo "https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-windows-amd64.msi"
      echo "Then run (Admin CMD):"
      echo "cloudflared.exe service install <TOKEN>"
      ;;
    4)
      read -rp "Cloudflare Tunnel Token: " cloudtoken
      docker run cloudflare/cloudflared:latest tunnel --no-autoupdate run --token "$cloudtoken"
      ;;
    *)
      echo "Invalid option"
      ;;
  esac
  echo ""
}

start_tunnel() {
  if [ -z "${cloudtoken:-}" ]; then
    echo ""
    echo -e "\033[1;31m Error: cloudtoken variable is empty. Set \$cloudtoken and retry.\033[0m"
    echo ""
    return 1
  fi

  echo ""
  echo -e "\033[1;34m Starting cloudflared tunnel...\033[0m"

  local start_cmd=("cloudflared" "tunnel" "run" "--token" "$cloudtoken")
  if command -v setsid >/dev/null 2>&1; then
    start_cmd=(setsid "${start_cmd[@]}")
  fi

  echo -e "\033[1;37m Command:\033[0m ${start_cmd[*]}"

  # Run detached so Ctrl+C or closing the menu does not kill the tunnel.
  if command -v nohup >/dev/null 2>&1; then
    nohup bash -c 'trap "" INT HUP; exec "$@"' _ "${start_cmd[@]}" >"$LOGFILE" 2>&1 </dev/null &
  else
    ( trap '' INT HUP; "${start_cmd[@]}" >"$LOGFILE" 2>&1 </dev/null ) &
  fi

  CF_PID=$!
  echo "$CF_PID" > "$PIDFILE" || true

  sleep 1
  show_configured_tunnels

  echo -e "\033[1;37m  cloudflared PID:  $CF_PID  \033[0m"
  echo -e "\033[1;31m  To stop the tunnel:  kill $CF_PID  \033[0m"
  echo -e "\033[1;30m  Log file: $LOGFILE\033[0m"
  echo ""
}

kill_tunnel() {
  echo ""
  pid="$(find_cloudflared_pid || true)"
  if [ -n "$pid" ]; then
    echo -e "\033[1;33m cloudflared tunnel is running (PID: $pid)\033[0m"
    echo -e "\033[1;31m Killing cloudflared tunnel (PID: $pid)...\033[0m"
    kill "$pid" && sleep 1
    if ! is_running_pid "$pid"; then
      echo -e "\033[1;32m cloudflared tunnel stopped.\033[0m"
      rm -f "$PIDFILE" 2>/dev/null || true
    else
      echo -e "\033[1;31m Failed to stop cloudflared (PID: $pid).\033[0m"
      return 2
    fi
  else
    echo -e "\033[1;31m No running cloudflared tunnel found.\033[0m"
  fi
  echo ""
}

ps_info() {
  # Cross-platform ps
  local pid="$1"
  if ps -p "$pid" -o etime=,pcpu=,rss=,command= 2>/dev/null; then
    return 0
  fi
  ps -p "$pid" -o etime,pcpu,rss,command 2>/dev/null | tail -n +2
}

ps_command() {
  local pid="$1"
  ps -p "$pid" -o command= 2>/dev/null || ps -p "$pid" -o command 2>/dev/null | tail -n +2
}

port_listening() {
  local port="$1"
  if command -v lsof >/dev/null 2>&1; then
    lsof -nP -iTCP:"$port" -sTCP:LISTEN -t 2>/dev/null | head -n1
  elif command -v ss >/dev/null 2>&1; then
    ss -ltn 2>/dev/null | awk -v p=":$port" '$4 ~ p {print "ok"; exit}'
  elif command -v netstat >/dev/null 2>&1; then
    netstat -an 2>/dev/null | awk -v p=":$port " '$0 ~ p && /LISTEN/ {print "ok"; exit}'
  fi
}

check_local_port() {
  local label="$1" port="$2" color="$3"
  local found
  found="$(port_listening "$port" || true)"
  if [ -n "$found" ]; then
    printf "  \033[1;32m[OK]\033[0m   %b%-18s\033[0m -> port %s listening (pid/info: %s)\n" "$color" "$label" "$port" "$found"
  else
    printf "  \033[1;31m[DOWN]\033[0m %b%-18s\033[0m -> port %s NOT listening\n" "$color" "$label" "$port"
  fi
}

connection_state_from_log() {
  [ -f "$LOGFILE" ] || { echo "no-log"; return; }
  local registered failed
  registered="$(grep -c "Registered tunnel connection" "$LOGFILE" 2>/dev/null || echo 0)"
  failed="$(grep -cE "ERR|error=|Unable to|failed to" "$LOGFILE" 2>/dev/null || echo 0)"
  if [ "${registered:-0}" -gt 0 ]; then
    echo "connected:$registered"
  elif [ "${failed:-0}" -gt 0 ]; then
    echo "errors:$failed"
  else
    echo "unknown"
  fi
}

status_and_tunnels() {
  echo ""
  pid="$(find_cloudflared_pid || true)"

  # Process state
  echo -e "\033[1;36m-- Process --\033[0m"
  if [ -n "$pid" ]; then
    echo -e "  \033[1;32m[RUNNING]\033[0m cloudflared PID: $pid"
    local cmd info
    cmd="$(ps_command "$pid" || true)"
    if [ -n "$cmd" ]; then
      echo -e "  \033[1;37mCommand:\033[0m $cmd"
    fi
    info="$(ps_info "$pid" || true)"
    if [ -n "$info" ]; then
      echo -e "  \033[1;37mInfo (etime cpu% rss cmd):\033[0m"
      echo "    $info"
    fi
  else
    echo -e "  \033[1;31m[STOPPED]\033[0m no cloudflared process found"
  fi
  echo ""

  # Connection state (parsed from log)
  echo -e "\033[1;36m-- Connection state (from log) --\033[0m"
  if [ -f "$LOGFILE" ]; then
    local cstate
    cstate="$(connection_state_from_log)"
    case "$cstate" in
      connected:*)
        echo -e "  \033[1;32m[CONNECTED]\033[0m registered connections: ${cstate#connected:}"
        ;;
      errors:*)
        echo -e "  \033[1;31m[ERRORS]\033[0m error lines in log: ${cstate#errors:}"
        ;;
      no-log)
        echo -e "  \033[1;33m[NO-LOG]\033[0m $LOGFILE not found"
        ;;
      *)
        echo -e "  \033[1;33m[UNKNOWN]\033[0m no registration nor error markers yet"
        ;;
    esac
    echo -e "  \033[1;37mLast 6 log lines:\033[0m"
    tail -n 6 "$LOGFILE" 2>/dev/null | sed 's/^/    /'
  else
    echo -e "  \033[1;33m[NO-LOG]\033[0m $LOGFILE not found"
  fi
  echo ""

  # Local services the tunnel routes to
  echo -e "\033[1;36m-- Local backends (tunnel targets) --\033[0m"
  check_local_port "http.4rji.com"  80   "\033[1;32m"
  check_local_port "3000.4rji.com"  3000 "\033[1;33m"
  check_local_port "8080.4rji.com"  8080 "\033[1;35m"
  check_local_port "9000.4rji.com"  9000 "\033[1;35m"
  check_local_port "smb.4rji.com"   445  "\033[1;36m"
  check_local_port "sssh.4rji.com"  22   "\033[1;36m"
  echo ""

  show_configured_tunnels

  if command -v cloudflared >/dev/null 2>&1 && [ -d "$HOME/.cloudflared" ]; then
    echo -e "\033[1;37m cloudflared tunnel list:\033[0m"
    cloudflared tunnel list 2>/dev/null || echo "    (not authenticated or no tunnels)"
    echo ""
  fi

  if [ -n "${pid:-}" ]; then
    echo -e "\033[1;31m To stop: option 3 or k, or: kill $pid\033[0m"
  fi
  echo -e "\033[1;30m Log: $LOGFILE   PID file: $PIDFILE\033[0m"
  echo ""
}

menu() {
  echo ""
  echo -e "\033[1;36m================== cloudflared menu ==================\033[0m"
  echo -e "\033[1;32m  1) Start tunnel\033[0m"
  echo -e "\033[1;35m  2) Status + tunnels\033[0m"
  echo -e "\033[1;31m  3) Kill tunnel (alias: k)\033[0m"
  echo -e "\033[1;33m  4) Install cloudflared (wget binary)\033[0m"
  echo -e "\033[1;33m  5) Install cloudflared (apt / brew / win / docker)\033[0m"
  echo -e "\033[1;31m  k) Kill tunnel\033[0m"
  echo -e "\033[1;37m  q) Quit\033[0m"
  echo -e "\033[1;36m======================================================\033[0m"
  echo ""
  echo -e "\033[1;30mNOTE:\033[0m"
  echo -e "\033[1;30m  ./cloudflared-linux-amd64 tunnel run --token \$cloudtoken &\033[0m"
  echo ""
}

while true; do
  menu
  read -n1 -rp "Option: " choice
  echo ""
  case "$choice" in
    1) start_tunnel ;;
    2) status_and_tunnels ;;
    3|k|K) kill_tunnel ;;
    4) install_cloudflared_wget ;;
    5) install_cloudflared_os ;;
    q|Q)
       echo "Bye."
       exit 0
       ;;
    *)
       echo -e "\033[1;31m Invalid option\033[0m"
       ;;
  esac
done
