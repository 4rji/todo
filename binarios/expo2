#!/usr/bin/env bash
set -euo pipefail

copy_clip() {
    if command -v pbcopy >/dev/null;       then pbcopy
    elif command -v xclip >/dev/null;      then xclip -sel clip
    elif command -v wl-copy >/dev/null;    then wl-copy
    else cat >/dev/null; return 1
    fi
}

extractPorts() {
    local file=$1 ports ip_address
    ports=$(grep -oE '[0-9]{1,5}/open' "$file" | cut -d/ -f1 | paste -sd, -)
    ip_address=$(grep -oE '([0-9]{1,3}\.){3}[0-9]{1,3}' "$file" | sort -u | head -n 1)

    [[ -z "$ports" ]] && { printf '\e[31mNo open ports found in %s\e[0m\n' "$file"; return 1; }

    printf '\n[*] Extracting information...\n\n'
    printf '\t[*] IP Address: %s\n' "$ip_address"
    printf '\t[*] Open ports: %s\n\n' "$ports"

    if printf '%s' "$ports" | copy_clip; then
        printf '[*] Ports copied to clipboard\n\n'
    else
        printf '\e[33m[!] No clipboard tool (pbcopy/xclip/wl-copy). Skipping copy.\e[0m\n\n'
    fi
}

file_path=./allPorts

if [[ -f "$file_path" ]]; then
    echo "Procesando archivo $file_path..."
    extractPorts "$file_path"
else
    echo "El archivo $file_path no existe."
    exit 1
fi

if command -v expo3 >/dev/null; then
    expo3
else
    printf '\e[31mexpo3 no encontrado en PATH\e[0m\n'
    exit 1
fi
