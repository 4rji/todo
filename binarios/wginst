#!/usr/bin/env bash

RED='\033[1;31m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
CYAN='\033[1;36m'
BLUE='\033[1;34m'
MAGENTA='\033[1;35m'
RESET='\033[0m'
SEP="${YELLOW}_________________________________________________________${RESET}"

paquetes=("wireguard" "resolvconf")

paquete_instalado_apt()    { dpkg -l "$1" | grep -q '^ii'; }
paquete_instalado_yum()    { yum list installed "$1" &>/dev/null; }
paquete_instalado_dnf()    { dnf list installed "$1" &>/dev/null; }
paquete_instalado_pacman() { pacman -Qi "$1" &>/dev/null; }

if [ -f /etc/os-release ]; then
  . /etc/os-release
  OS=$ID
fi

echo -e "\n${SEP}\n"
echo -e "${BLUE}[*] Installing packages...${RESET}\n"

for paquete in "${paquetes[@]}"; do
  case $OS in
    debian|ubuntu|kali)
      if ! paquete_instalado_apt "$paquete"; then sudo apt-get install -y "$paquete"; fi;;
    centos|rhel)
      if ! paquete_instalado_yum "$paquete"; then sudo yum install -y "$paquete"; fi;;
    fedora)
      if ! paquete_instalado_dnf "$paquete"; then sudo dnf install -y "$paquete"; fi;;
    arch)
      if ! paquete_instalado_pacman "$paquete"; then sudo pacman -S --noconfirm "$paquete"; fi;;
    *) echo -e "${RED}[!] Unknown OS: $OS${RESET}";;
  esac
done

setup_wireguard() {
  echo -e "\n${CYAN}[*] Copying config to /etc/wireguard/${RESET}"
  sudo cp "$config_file" "/etc/wireguard/$file_name"
  sudo chmod 600 "/etc/wireguard/$file_name"

  echo -e "${MAGENTA}[*] Bringing up $interface_name...${RESET}"
  sudo wg-quick up "$interface_name"

  echo -e "${CYAN}[*] Interface status:${RESET}"
  sudo wg

  echo -e "${RED}[*] Public IP:${RESET}"
  curl -s ifconfig.me; echo
}

if [ -z "$1" ]; then
  echo -e "${RED}[!] Usage: $0 <path/to/file.conf>${RESET}"
  exit 1
else
  config_file=$1
  file_name=$(basename "$config_file")
  interface_name="${file_name%.*}"
  setup_wireguard
fi

echo -e "\n${SEP}\n"

# check_wg.sh — ensures interface stays up (runs every minute via cron)
echo -e "${GREEN}[*] Creating /usr/local/bin/check_wg.sh...${RESET}"
sudo tee /usr/local/bin/check_wg.sh >/dev/null <<EOF
#!/bin/bash
INTERFACE="${interface_name}"
if ! wg show "\$INTERFACE" >/dev/null 2>&1; then
  sudo wg-quick up "\$INTERFACE"
fi
EOF
sudo chmod +x /usr/local/bin/check_wg.sh

# bb8reconnect.sh — forced reconnect every 30 min
echo -e "${GREEN}[*] Creating /usr/local/bin/bb8reconnect.sh...${RESET}"
sudo tee /usr/local/bin/bb8reconnect.sh >/dev/null <<EOF
#!/bin/bash
IF="${interface_name}"
sudo wg-quick down "\$IF" 2>/dev/null || true
sudo wg-quick up "\$IF"
EOF
sudo chmod +x /usr/local/bin/bb8reconnect.sh

echo -e "${GREEN}[*] Updating root crontab...${RESET}"
( sudo crontab -l 2>/dev/null \
    | grep -v '/usr/local/bin/check_wg.sh' \
    | grep -v '/usr/local/bin/bb8reconnect.sh'; \
  echo "* * * * * /usr/local/bin/check_wg.sh"; \
  echo "*/30 * * * * /usr/local/bin/bb8reconnect.sh" ) | sudo crontab -

echo -e "\n${SEP}\n"
echo -e "${GREEN}[+] Done.${RESET} Interface: ${CYAN}$interface_name${RESET}\n"
echo -e "${BLUE}Crontab:${RESET}"
sudo crontab -l
echo
