#!/usr/bin/env bash

# Instalador y configurador de bat + fzf + thefuck + zoxide
# Detecta OS, instala, crea symlinks bat<->batcat, configura zshrc

BOLD='\033[1m'
RED='\033[1;31m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
BLUE='\033[1;34m'
CYAN='\033[1;36m'
NC='\033[0m'

ZSHRC="${HOME}/.zshrc"
BAT_BIN=""

# ─── Detectar OS ──────────────────────────────────────────────────────────────
detect_os() {
    if [ -f /etc/os-release ]; then
        . /etc/os-release
        OS_ID="$ID"
        OS_LIKE="${ID_LIKE:-}"
    elif command -v uname &>/dev/null; then
        OS_ID="$(uname -s | tr '[:upper:]' '[:lower:]')"
        OS_LIKE=""
    else
        OS_ID="unknown"
        OS_LIKE=""
    fi
}

os_family() {
    case "$OS_ID" in
        ubuntu|debian|kali|linuxmint|pop) echo "apt" ;;
        arch|manjaro|endeavouros)         echo "pacman" ;;
        fedora)                           echo "dnf" ;;
        rhel|centos|almalinux|rocky)      echo "yum" ;;
        darwin)                           echo "brew" ;;
        *)
            if echo "$OS_LIKE" | grep -q "debian\|ubuntu";  then echo "apt"
            elif echo "$OS_LIKE" | grep -q "arch";          then echo "pacman"
            elif echo "$OS_LIKE" | grep -q "fedora\|rhel";  then echo "dnf"
            else echo "unknown"
            fi
            ;;
    esac
}

# ─── Helpers ─────────────────────────────────────────────────────────────────
ok()   { echo -e "${GREEN}✔ $*${NC}"; }
info() { echo -e "${CYAN}→ $*${NC}"; }
warn() { echo -e "${YELLOW}⚠ $*${NC}"; }
err()  { echo -e "${RED}✘ $*${NC}"; }

append_zshrc() {
    local line="$1"
    grep -qF "$line" "$ZSHRC" 2>/dev/null || echo "$line" >> "$ZSHRC"
}

resolve_bat_bin() {
    if command -v batcat &>/dev/null; then
        BAT_BIN="batcat"
    elif command -v bat &>/dev/null; then
        BAT_BIN="bat"
    fi
}

# ─── Symlinks bat <-> batcat ──────────────────────────────────────────────────
fix_bat_aliases() {
    resolve_bat_bin
    if [ -z "$BAT_BIN" ]; then
        err "bat no está instalado, no se pueden crear los symlinks"
        return 1
    fi

    local real_path
    real_path="$(command -v "$BAT_BIN")"
    local dir
    dir="$(dirname "$real_path")"

    if [ "$BAT_BIN" = "batcat" ] && ! command -v bat &>/dev/null; then
        info "Creando symlink: $dir/bat -> $real_path"
        sudo ln -sf "$real_path" "$dir/bat"
        ok "Ahora funcionan tanto 'bat' como 'batcat'"
    elif [ "$BAT_BIN" = "bat" ] && ! command -v batcat &>/dev/null; then
        info "Creando symlink: $dir/batcat -> $real_path"
        sudo ln -sf "$real_path" "$dir/batcat"
        ok "Ahora funcionan tanto 'bat' como 'batcat'"
    else
        ok "Ya existen ambos: 'bat' y 'batcat'"
    fi
}

# ─── Instaladores ─────────────────────────────────────────────────────────────
install_bat() {
    local pkg_mgr
    pkg_mgr="$(os_family)"
    info "OS: $OS_ID ($pkg_mgr)"

    case "$pkg_mgr" in
        apt)
            sudo apt-get update -qq
            sudo apt-get install -y bat
            ;;
        pacman)
            sudo pacman -Sy --noconfirm bat
            ;;
        dnf)
            sudo dnf install -y bat
            ;;
        yum)
            info "Instalando desde EPEL..."
            sudo yum install -y epel-release
            if ! sudo yum install -y bat 2>/dev/null; then
                warn "EPEL falló. Descargando desde GitHub..."
                local ver="0.24.0"
                local url="https://github.com/sharkdp/bat/releases/download/v${ver}/bat-v${ver}-x86_64-unknown-linux-gnu.tar.gz"
                local tmp
                tmp="$(mktemp -d)"
                curl -Lo "$tmp/bat.tar.gz" "$url"
                tar -xzf "$tmp/bat.tar.gz" -C "$tmp"
                sudo cp "$tmp/bat-v${ver}-x86_64-unknown-linux-gnu/bat" /usr/local/bin/bat
                rm -rf "$tmp"
            fi
            ;;
        brew)
            brew install bat
            ;;
        *)
            err "Package manager no reconocido. Instalá bat manualmente."
            return 1
            ;;
    esac

    resolve_bat_bin
    if [ -n "$BAT_BIN" ]; then
        ok "bat instalado correctamente ($BAT_BIN)"
        fix_bat_aliases
    else
        err "Instalación falló"
        return 1
    fi
}

install_bat_theme() {
    resolve_bat_bin
    if [ -z "$BAT_BIN" ]; then
        err "bat no está instalado"
        return 1
    fi

    local themes_dir="${HOME}/.config/bat/themes"
    mkdir -p "$themes_dir"
    info "Descargando tema tokyonight_night..."
    curl -sLo "$themes_dir/tokyonight_night.tmTheme" \
        "https://raw.githubusercontent.com/folke/tokyonight.nvim/main/extras/sublime/tokyonight_night.tmTheme"
    "$BAT_BIN" cache --build
    append_zshrc 'export BAT_THEME="tokyonight_night"'
    ok "Tema tokyonight_night configurado"
}

install_fzf() {
    local pkg_mgr
    pkg_mgr="$(os_family)"
    case "$pkg_mgr" in
        apt)    sudo apt-get install -y fzf ;;
        pacman) sudo pacman -Sy --noconfirm fzf ;;
        dnf)    sudo dnf install -y fzf ;;
        yum)    sudo yum install -y fzf ;;
        brew)   brew install fzf ;;
        *)      err "Instalá fzf manualmente"; return 1 ;;
    esac
    ok "fzf instalado"

    append_zshrc '[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh'
    append_zshrc "export FZF_CTRL_T_OPTS=\"--preview 'bat -n --color=always --line-range :500 {}'\""
    append_zshrc "export FZF_ALT_C_OPTS=\"--preview 'eza --tree --color=always {} | head -200'\""

    # _fzf_comprun
    if ! grep -q '_fzf_comprun' "$ZSHRC" 2>/dev/null; then
        cat >> "$ZSHRC" <<'EOF'

_fzf_comprun() {
  local command=$1
  shift
  case "$command" in
    cd)           fzf --preview 'eza --tree --color=always {} | head -200' "$@" ;;
    export|unset) fzf --preview "eval 'echo \$'{}" "$@" ;;
    ssh)          fzf --preview 'dig {}' "$@" ;;
    *)            fzf --preview "bat -n --color=always --line-range :500 {}" "$@" ;;
  esac
}
EOF
    fi
    ok "fzf configurado en $ZSHRC"
}

install_thefuck() {
    local pkg_mgr
    pkg_mgr="$(os_family)"
    case "$pkg_mgr" in
        apt)    sudo apt-get install -y thefuck ;;
        pacman) sudo pacman -Sy --noconfirm thefuck ;;
        dnf)    sudo dnf install -y thefuck ;;
        brew)   brew install thefuck ;;
        *)
            if command -v pip3 &>/dev/null; then
                pip3 install --user thefuck
            else
                err "Instalá thefuck manualmente (pip3 install thefuck)"
                return 1
            fi
            ;;
    esac
    append_zshrc 'eval $(thefuck --alias)'
    append_zshrc 'eval $(thefuck --alias fk)'
    ok "thefuck instalado (alias: fk)"
}

install_zoxide() {
    local pkg_mgr
    pkg_mgr="$(os_family)"
    case "$pkg_mgr" in
        apt)    sudo apt-get install -y zoxide ;;
        pacman) sudo pacman -Sy --noconfirm zoxide ;;
        dnf)    sudo dnf install -y zoxide ;;
        brew)   brew install zoxide ;;
        *)
            if command -v cargo &>/dev/null; then
                cargo install zoxide --locked
            else
                err "Instalá zoxide manualmente"
                return 1
            fi
            ;;
    esac
    append_zshrc 'eval "$(zoxide init zsh)"'
    ok "zoxide instalado"
}

# ─── Menú ─────────────────────────────────────────────────────────────────────
show_menu() {
    echo ""
    echo -e "${BOLD}${BLUE}════════════════════════════════════════${NC}"
    echo -e "${BOLD}      bat / fzf / thefuck / zoxide${NC}"
    echo -e "${BLUE}════════════════════════════════════════${NC}"
    detect_os
    echo -e "  OS detectado: ${YELLOW}${OS_ID}${NC} ($(os_family))"
    echo ""

    resolve_bat_bin
    local bat_status fzf_status fk_status zox_status
    bat_status="${RED}no instalado${NC}"
    fzf_status="${RED}no instalado${NC}"
    fk_status="${RED}no instalado${NC}"
    zox_status="${RED}no instalado${NC}"
    [ -n "$BAT_BIN" ]               && bat_status="${GREEN}✔ $BAT_BIN${NC}"
    command -v fzf    &>/dev/null   && fzf_status="${GREEN}✔ $(command -v fzf)${NC}"
    command -v thefuck &>/dev/null  && fk_status="${GREEN}✔ $(command -v thefuck)${NC}"
    command -v zoxide &>/dev/null   && zox_status="${GREEN}✔ $(command -v zoxide)${NC}"

    echo -e "  1) Instalar bat                 [$bat_status]"
    echo -e "  2) Configurar tema tokyonight   (requiere bat)"
    echo -e "  3) Crear symlinks bat <-> batcat"
    echo -e "  4) Instalar fzf + configurar    [$fzf_status]"
    echo -e "  5) Instalar thefuck (alias: fk) [$fk_status]"
    echo -e "  6) Instalar zoxide              [$zox_status]"
    echo -e "  ${BOLD}7) Instalar todo${NC}"
    echo -e "  0) Salir"
    echo ""
    echo -e "${BLUE}════════════════════════════════════════${NC}"
}

main() {
    detect_os

    while true; do
        show_menu
        read -rp "$(echo -e "${CYAN}Elegí una opción: ${NC}")" opt
        echo ""
        case "$opt" in
            1) install_bat ;;
            2) install_bat_theme ;;
            3) fix_bat_aliases ;;
            4) install_fzf ;;
            5) install_thefuck ;;
            6) install_zoxide ;;
            7)
                install_bat
                install_bat_theme
                fix_bat_aliases
                install_fzf
                install_thefuck
                install_zoxide
                echo ""
                ok "Todo instalado. Recargá zsh: source ~/.zshrc"
                ;;
            0) echo "Chau."; exit 0 ;;
            *) warn "Opción inválida" ;;
        esac
        echo ""
        read -rp "$(echo -e "${YELLOW}Enter para continuar...${NC}")"
    done
}

main
