#!/usr/bin/env bash
# Download a YouTube video's audio as MP3, or transcribe a local media file, with OpenAI.

set -euo pipefail

usage() {
  cat <<'EOF'
Usage: ./youtube-to-md <youtube-url-or-local-file>

Requirements: yt-dlp, ffmpeg and curl.
Set OPENAI_API_KEY in the environment before running.

For a URL, the MP3 and resulting .md file are saved in the current directory.
For a local file, the original is kept and its .md is saved beside it.
EOF
}

fail() {
  echo "Error: $*" >&2
  exit 1
}

[[ $# -eq 1 ]] || { usage >&2; exit 2; }
[[ -n "${OPENAI_API_KEY:-}" ]] || fail "OPENAI_API_KEY is not set."

for command in yt-dlp ffmpeg curl; do
  command -v "$command" >/dev/null 2>&1 || fail "'$command' is required but was not found in PATH."
done

work_dir="$(mktemp -d "${TMPDIR:-/tmp}/youtube-to-md.XXXXXX")"
trap 'rm -rf "$work_dir"' EXIT

input="$1"
if [[ -f "$input" ]]; then
  audio_path="$input"
  markdown_path="${input%.*}.md"
  echo "Using local file: $audio_path" >&2
else
  echo "Downloading MP3..." >&2
  audio_path="$(yt-dlp \
    --no-playlist \
    --extract-audio \
    --audio-format mp3 \
    --audio-quality 0 \
    --paths . \
    --print after_move:filepath \
    "$input")"
  [[ -f "$audio_path" ]] || fail "yt-dlp did not produce an MP3 file."
  markdown_path="${audio_path%.*}.md"
fi

[[ ! -e "$markdown_path" ]] || fail "Output already exists: $markdown_path"

# Match the app's cloud-audio preparation: mono, 16 kHz, 64 kbps MP3.
normalized="$work_dir/normalized.mp3"
echo "Preparing audio for transcription..." >&2
ffmpeg -hide_banner -loglevel error -y \
  -i "$audio_path" -map 0:a:0 -vn -ac 1 -ar 16000 \
  -c:a libmp3lame -b:a 64k "$normalized"

# OpenAI's upload limit is 25 MB.  At 64 kbps, 45-minute parts stay below it.
if [[ $(wc -c < "$normalized") -gt 25000000 ]]; then
  ffmpeg -hide_banner -loglevel error -y \
    -i "$normalized" -f segment -segment_time 2700 -reset_timestamps 1 \
    -c copy "$work_dir/chunk-%04d.mp3"
  parts=("$work_dir"/chunk-*.mp3)
else
  parts=("$normalized")
fi

echo "Transcribing with OpenAI..." >&2
for part in "${parts[@]}"; do
  response="$work_dir/$(basename "$part").txt"
  curl --fail-with-body --silent --show-error \
    https://api.openai.com/v1/audio/transcriptions \
    -H "Authorization: Bearer $OPENAI_API_KEY" \
    -F "file=@$part" \
    -F "model=gpt-4o-transcribe" \
    -F "response_format=text" > "$response"
  cat "$response" >> "$markdown_path"
  printf '\n\n' >> "$markdown_path"
done

echo "MP3: $audio_path"
echo "Markdown: $markdown_path"
