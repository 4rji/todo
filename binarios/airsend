#!/usr/bin/env bash

set -e

sistema="$(uname -s)"
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

case "$sistema" in
    Linux)
        binario="$script_dir/airsend_amd"
        ;;
    Darwin)
        binario="$script_dir/airsendm"
        ;;
    *)
        echo "Sistema operativo no soportado: $sistema" >&2
        exit 1
        ;;
esac

if [[ ! -x "$binario" ]]; then
    echo "No se encontro el binario ejecutable: $binario" >&2
    exit 1
fi

exec "$binario" "$@"
