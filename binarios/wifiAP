#!/usr/bin/env bash

set -euo pipefail

if [[ -t 1 ]]; then
  C_RESET=$'\033[0m'
  C_BOLD=$'\033[1m'
  C_GREEN=$'\033[32m'
  C_YELLOW=$'\033[33m'
  C_BLUE=$'\033[34m'
  C_CYAN=$'\033[36m'
  C_DIM=$'\033[2m'
else
  C_RESET=""
  C_BOLD=""
  C_GREEN=""
  C_YELLOW=""
  C_BLUE=""
  C_CYAN=""
  C_DIM=""
fi

usage() {
  printf "%sUsage:%s\n" "$C_BOLD$C_BLUE" "$C_RESET"
  printf "  ./wifiAP -AP <ap_interface> [-i <internet_interface>] [-s <ssid>] [-c <channel>] [-C <country>] [-2]\n\n"
  printf "  ./wifiAP -k [-AP <ap_interface>]\n\n"

  printf "%sRecommended for Internet sharing:%s\n" "$C_BOLD$C_GREEN" "$C_RESET"
  printf "  sudo ./wifiAP -AP wlan0 -i wlan1\n\n"

  printf "%sExamples:%s\n" "$C_BOLD$C_BLUE" "$C_RESET"
  printf "  ./wifiAP -AP wlan0                             %s# create local-only eduroam2 network (no Internet)%s\n" "$C_CYAN" "$C_RESET"
  printf "  ./wifiAP -AP wlan0 -i wlan1                    %s# same simple network but with Internet%s\n" "$C_CYAN" "$C_RESET"
  printf "  ./wifiAP -AP wlan2 -i wlan1 -s MyOpenAP -c 11  %s# create MyOpenAP network on channel 11%s\n" "$C_CYAN" "$C_RESET"
  printf "  ./wifiAP -AP wlan0 -i wlan1 -2                 %s# legacy 2.4GHz only (max compat)%s\n" "$C_CYAN" "$C_RESET"
  printf "  ./wifiAP -AP wlan0 -i wlan1 -C AR              %s# set country code%s\n" "$C_CYAN" "$C_RESET"
  printf "  ./wifiAP -AP wlan0 -i wlan1 -p 12341234        %s# create network with WPA2 password%s\n\n" "$C_CYAN" "$C_RESET"
  printf "  sudo ./wifiAP -k -AP wlan0                     %s# stop the AP created on wlan0%s\n" "$C_CYAN" "$C_RESET"
  printf "  sudo ./wifiAP -k                               %s# stop all APs created by wifiAP%s\n\n" "$C_CYAN" "$C_RESET"

  printf "%sArguments:%s\n" "$C_BOLD$C_BLUE" "$C_RESET"
  printf "  -AP Wireless interface that will become the Access Point.\n"
  printf "  -i  Interface that already has Internet access and will be shared.\n"
  printf "  -s  Open Wi-Fi name. Default: eduroam2\n"
  printf "  -c  Wi-Fi channel (1, 6, 11 recommended). Default: 6\n"
  printf "  -C  Country code (regulatory domain). Default: US\n"
  printf "  -p  WPA2-PSK password (8-63 chars). If omitted, AP is open.\n"
  printf "  -2  Force legacy 2.4GHz mode (802.11g only, no 802.11n).\n"
  printf "      Use for very old/picky devices (some IoT, old Hak5 gear).\n\n"
  printf "  -k  Kill/clean wifiAP-created APs. With -AP, stops that interface only.\n\n"

  printf "%sNotes:%s\n" "$C_BOLD$C_YELLOW" "$C_RESET"
  printf "  - Creates an open Access Point with no password.\n"
  printf "  - Default mode: 2.4GHz + 802.11n + WMM (best compatibility for modern devices).\n"
  printf "  - The script always starts DHCP on the AP interface.\n"
  printf "  - Omit -i to create a local-only/offline AP for direct access to this device.\n"
  printf "  - Clients receive addresses in 10.55.0.0/24 and can reach this device at 10.55.0.1.\n"
  printf "  - If -i is provided, the script also enables NAT for Internet sharing.\n"
  printf "  - Only the AP interface is reconfigured.\n"
  printf "  - Your Internet connection stays up as long as it uses a different interface.\n"
  printf "  - Requires hostapd and dnsmasq. Internet sharing also requires iptables.\n"
  printf "  - Use -k to stop an AP started by this script from another terminal.\n"
}

if [[ ${1:-} == "-h" || ${1:-} == "--help" ]]; then
  usage
  exit 0
fi

if [[ $# -eq 0 ]]; then
  usage
  exit 0
fi

if [[ $EUID -ne 0 ]]; then
  exec sudo -- "$0" "$@"
fi

if [[ $# -gt 0 && ${1:-} != -* ]]; then
  echo "This script requires flags. See --help for usage." >&2
  usage
  exit 1
fi

AP_IFACE=""
WAN_IFACE=""
SSID="eduroam2"
CHANNEL="6"
COUNTRY="US"
LEGACY_MODE=0
PASSWORD=""
AP_ADDR="10.55.0.1"
AP_CIDR="24"
AP_SUBNET="10.55.0.0/24"
DHCP_START="10.55.0.10"
DHCP_END="10.55.0.100"
KILL_MODE=0
STATE_DIR="/run/wifiAP"
STATE_FILE=""
CONTROLLER_PID="$$"
CONTROLLER_STARTTIME=""
HOSTAPD_CONF=""
DNSMASQ_CONF=""
HOSTAPD_PID=""
DNSMASQ_PID=""
NM_MANAGED_CHANGED=0
NM_PREV_CONN=""
AP_ORIG_CAPTURED=0
AP_ORIG_LINK_UP=""
AP_ORIG_TYPE=""
AP_ORIG_IPV4_ADDRS=""
AP_ORIG_IPV6_ADDRS=""
AP_ORIG_NM_MANAGED=""
AP_ORIG_NM_STATE=""
IP_FORWARD_OLD=""
IPTABLES_NAT_ADDED=0
IPTABLES_FWD1_ADDED=0
IPTABLES_FWD2_ADDED=0
IPTABLES_MSS_ADDED=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    -AP)
      if [[ $# -lt 2 ]]; then
        echo "Option -AP requires a value." >&2
        usage
        exit 1
      fi
      AP_IFACE="$2"
      shift 2
      ;;
    -i)
      if [[ $# -lt 2 ]]; then
        echo "Option -i requires a value." >&2
        usage
        exit 1
      fi
      WAN_IFACE="$2"
      shift 2
      ;;
    -s)
      if [[ $# -lt 2 ]]; then
        echo "Option -s requires a value." >&2
        usage
        exit 1
      fi
      SSID="$2"
      shift 2
      ;;
    -c)
      if [[ $# -lt 2 ]]; then
        echo "Option -c requires a value." >&2
        usage
        exit 1
      fi
      CHANNEL="$2"
      shift 2
      ;;
    -C)
      if [[ $# -lt 2 ]]; then
        echo "Option -C requires a value." >&2
        usage
        exit 1
      fi
      COUNTRY="$2"
      shift 2
      ;;
    -p)
      if [[ $# -lt 2 ]]; then
        echo "Option -p requires a value." >&2
        usage
        exit 1
      fi
      PASSWORD="$2"
      shift 2
      ;;
    -2)
      LEGACY_MODE=1
      shift
      ;;
    -k)
      KILL_MODE=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      usage
      exit 1
      ;;
  esac
done

state_file_for_iface() {
  local iface="$1"
  printf '%s/%s.state' "$STATE_DIR" "$iface"
}

validate_state_iface() {
  local iface="$1"

  if [[ -z "$iface" ]]; then
    echo "AP interface is required." >&2
    exit 1
  fi

  if [[ "$iface" == */* ]]; then
    echo "Interface name cannot contain '/'." >&2
    exit 1
  fi
}

ensure_state_dir() {
  mkdir -p "$STATE_DIR"
  chmod 700 "$STATE_DIR"
}

process_starttime() {
  local pid="$1"
  awk '{print $22}' "/proc/$pid/stat" 2>/dev/null || true
}

pid_cmdline() {
  local pid="$1"
  tr '\0' ' ' < "/proc/$pid/cmdline" 2>/dev/null || true
}

wait_for_pid_exit() {
  local pid="$1"

  for _ in {1..30}; do
    kill -0 "$pid" 2>/dev/null || return 0
    sleep 0.1
  done

  return 1
}

tracked_controller_running() {
  [[ -n "$CONTROLLER_PID" ]] || return 1
  [[ -n "$CONTROLLER_STARTTIME" ]] || return 1
  kill -0 "$CONTROLLER_PID" 2>/dev/null || return 1

  [[ "$(process_starttime "$CONTROLLER_PID")" == "$CONTROLLER_STARTTIME" ]]
}

stop_tracked_child() {
  local pid="$1"
  local process_name="$2"
  local expected_conf="${3:-}"
  local cmdline

  [[ -n "$pid" ]] || return 0
  kill -0 "$pid" 2>/dev/null || return 0

  if [[ -r "/proc/$pid/cmdline" ]]; then
    cmdline="$(pid_cmdline "$pid")"
    [[ "$cmdline" == *"$process_name"* ]] || return 0
    if [[ -n "$expected_conf" && "$cmdline" != *"$expected_conf"* ]]; then
      return 0
    fi
  fi

  kill "$pid" 2>/dev/null || true
  wait "$pid" 2>/dev/null || true
  if ! wait_for_pid_exit "$pid"; then
    cmdline="$(pid_cmdline "$pid")"
    if [[ "$cmdline" == *"$process_name"* ]]; then
      kill -KILL "$pid" 2>/dev/null || true
      wait_for_pid_exit "$pid" || true
    fi
  fi
}

iface_link_is_up() {
  local iface="$1"
  local flags

  flags="$(ip -o link show dev "$iface" 2>/dev/null | sed -n 's/^[^<]*<\([^>]*\)>.*/\1/p' || true)"
  [[ ",$flags," == *,UP,* ]]
}

iface_ipv4_addrs() {
  local iface="$1"

  ip -o -4 addr show dev "$iface" 2>/dev/null | awk '{printf "%s%s", sep, $4; sep=" "}' || true
}

iface_ipv6_addrs() {
  local iface="$1"

  ip -o -6 addr show dev "$iface" scope global 2>/dev/null | awk '{printf "%s%s", sep, $4; sep=" "}' || true
}

nm_device_state() {
  local iface="$1"

  nmcli -t -f DEVICE,STATE device 2>/dev/null | awk -F: -v d="$iface" '$1==d{print $2; exit}' || true
}

nm_device_managed() {
  local iface="$1"

  nmcli -t -f GENERAL.NM-MANAGED device show "$iface" 2>/dev/null | awk -F: 'NR==1{print $2; exit}' || true
}

capture_original_iface_state() {
  local iface="$1"

  AP_ORIG_CAPTURED=1

  if command -v ip >/dev/null 2>&1; then
    if iface_link_is_up "$iface"; then
      AP_ORIG_LINK_UP=1
    else
      AP_ORIG_LINK_UP=0
    fi
    AP_ORIG_IPV4_ADDRS="$(iface_ipv4_addrs "$iface")"
    AP_ORIG_IPV6_ADDRS="$(iface_ipv6_addrs "$iface")"
  fi

  if command -v iw >/dev/null 2>&1; then
    AP_ORIG_TYPE="$(iw dev "$iface" info 2>/dev/null | awk '$1=="type"{print $2; exit}' || true)"
  fi

  if command -v nmcli >/dev/null 2>&1; then
    AP_ORIG_NM_MANAGED="$(nm_device_managed "$iface")"
    AP_ORIG_NM_STATE="$(nm_device_state "$iface")"
    NM_PREV_CONN="$(nmcli -t -f NAME,DEVICE connection show --active 2>/dev/null | awk -F: -v d="$iface" '$2==d{print $1; exit}' || true)"
  fi

  write_state
}

restore_saved_ip_addrs() {
  local iface="$1"
  local addr

  for addr in $AP_ORIG_IPV4_ADDRS; do
    ip addr add "$addr" dev "$iface" 2>/dev/null || true
  done

  for addr in $AP_ORIG_IPV6_ADDRS; do
    ip -6 addr add "$addr" dev "$iface" 2>/dev/null || true
  done
}

should_restore_saved_ip_addrs() {
  if [[ $AP_ORIG_CAPTURED -ne 1 ]]; then
    return 1
  fi

  if ! command -v nmcli >/dev/null 2>&1; then
    return 0
  fi

  if [[ "$AP_ORIG_NM_STATE" == "unmanaged" ]]; then
    return 0
  fi

  case "$AP_ORIG_NM_MANAGED" in
    yes|YES|true|TRUE)
      return 1
      ;;
  esac

  return 0
}

restore_network_manager_state() {
  local iface="$1"
  local fallback_reset="${2:-0}"
  local state

  command -v nmcli >/dev/null 2>&1 || return 0

  if [[ $AP_ORIG_CAPTURED -eq 1 && "$AP_ORIG_NM_STATE" == "unmanaged" ]]; then
    nmcli device set "$iface" managed no >/dev/null 2>&1 || true
    return 0
  fi

  case "$AP_ORIG_NM_MANAGED" in
    no|NO|false|FALSE)
      nmcli device set "$iface" managed no >/dev/null 2>&1 || true
      return 0
      ;;
  esac

  if [[ $NM_MANAGED_CHANGED -eq 1 || $fallback_reset -eq 1 || -n "$AP_ORIG_NM_MANAGED" ]]; then
    nmcli device set "$iface" managed yes >/dev/null 2>&1 || true
    for _ in 1 2 3 4 5; do
      state="$(nm_device_state "$iface")"
      [[ "$state" != "unmanaged" && -n "$state" ]] && break
      sleep 1
    done

    if [[ -n "$NM_PREV_CONN" ]]; then
      nmcli connection up "$NM_PREV_CONN" ifname "$iface" >/dev/null 2>&1 \
        || nmcli connection up "$NM_PREV_CONN" >/dev/null 2>&1 \
        || nmcli device connect "$iface" >/dev/null 2>&1 || true
    elif [[ "$AP_ORIG_NM_STATE" == "connected" || "$AP_ORIG_NM_STATE" == "connecting" || $fallback_reset -eq 1 ]]; then
      nmcli device connect "$iface" >/dev/null 2>&1 || true
    fi
  fi
}

restore_ap_interface() {
  local iface="$1"
  local fallback_reset="${2:-0}"
  local target_type

  [[ -n "$iface" ]] || return 0

  if command -v ip >/dev/null 2>&1 && ip link show "$iface" >/dev/null 2>&1; then
    ip link set "$iface" down >/dev/null 2>&1 || true
    ip addr del "${AP_ADDR}/${AP_CIDR}" dev "$iface" >/dev/null 2>&1 || true

    if command -v iw >/dev/null 2>&1; then
      target_type="${AP_ORIG_TYPE:-managed}"
      iw dev "$iface" set type "$target_type" >/dev/null 2>&1 \
        || iw dev "$iface" set type managed >/dev/null 2>&1 || true
    fi

    if should_restore_saved_ip_addrs; then
      restore_saved_ip_addrs "$iface"
    fi

    if [[ "$AP_ORIG_LINK_UP" == "0" && $fallback_reset -eq 0 ]]; then
      ip link set "$iface" down >/dev/null 2>&1 || true
    else
      ip link set "$iface" up >/dev/null 2>&1 || true
    fi
  fi

  restore_network_manager_state "$iface" "$fallback_reset"
}

cleanup_resources() {
  local fallback_reset=1

  set +e

  stop_tracked_child "$HOSTAPD_PID" hostapd "$HOSTAPD_CONF"
  stop_tracked_child "$DNSMASQ_PID" dnsmasq "$DNSMASQ_CONF"

  if [[ $IPTABLES_NAT_ADDED -eq 1 && -n "$WAN_IFACE" ]] && command -v iptables >/dev/null 2>&1; then
    iptables -t nat -D POSTROUTING -s "$AP_SUBNET" -o "$WAN_IFACE" -j MASQUERADE 2>/dev/null || true
  fi

  if [[ $IPTABLES_FWD1_ADDED -eq 1 && -n "$WAN_IFACE" && -n "$AP_IFACE" ]] && command -v iptables >/dev/null 2>&1; then
    iptables -D FORWARD -i "$WAN_IFACE" -o "$AP_IFACE" -m state --state RELATED,ESTABLISHED -j ACCEPT 2>/dev/null || true
  fi

  if [[ $IPTABLES_FWD2_ADDED -eq 1 && -n "$AP_IFACE" && -n "$WAN_IFACE" ]] && command -v iptables >/dev/null 2>&1; then
    iptables -D FORWARD -i "$AP_IFACE" -o "$WAN_IFACE" -j ACCEPT 2>/dev/null || true
  fi

  if [[ $IPTABLES_MSS_ADDED -eq 1 && -n "$WAN_IFACE" ]] && command -v iptables >/dev/null 2>&1; then
    iptables -t mangle -D FORWARD -o "$WAN_IFACE" -p tcp --tcp-flags SYN,RST SYN -j TCPMSS --clamp-mss-to-pmtu 2>/dev/null || true
  fi

  if [[ -n "$IP_FORWARD_OLD" ]] && command -v sysctl >/dev/null 2>&1; then
    sysctl -w "net.ipv4.ip_forward=$IP_FORWARD_OLD" >/dev/null 2>&1 || true
  fi

  if [[ -n "$AP_IFACE" ]]; then
    if [[ $AP_ORIG_CAPTURED -eq 1 ]]; then
      fallback_reset=0
      restore_ap_interface "$AP_IFACE" "$fallback_reset"
    elif [[ $NM_MANAGED_CHANGED -eq 1 || -n "$DNSMASQ_CONF" || -n "$HOSTAPD_PID" || -n "$DNSMASQ_PID" ]]; then
      restore_ap_interface "$AP_IFACE" "$fallback_reset"
    fi
  fi

  rm -f "$HOSTAPD_CONF"
  rm -f "$DNSMASQ_CONF"
  [[ -n "$STATE_FILE" ]] && rm -f "$STATE_FILE"
}

cleanup() {
  cleanup_resources
}

load_state_file() {
  local state_file="$1"

  if [[ ! -f "$state_file" ]]; then
    return 1
  fi

  if [[ ! -O "$state_file" ]]; then
    echo "Skipping unsafe state file not owned by current user: $state_file" >&2
    return 1
  fi

  AP_IFACE=""
  WAN_IFACE=""
  AP_ADDR="10.55.0.1"
  AP_CIDR="24"
  AP_SUBNET="10.55.0.0/24"
  HOSTAPD_CONF=""
  DNSMASQ_CONF=""
  HOSTAPD_PID=""
  DNSMASQ_PID=""
  NM_MANAGED_CHANGED=0
  NM_PREV_CONN=""
  AP_ORIG_CAPTURED=0
  AP_ORIG_LINK_UP=""
  AP_ORIG_TYPE=""
  AP_ORIG_IPV4_ADDRS=""
  AP_ORIG_IPV6_ADDRS=""
  AP_ORIG_NM_MANAGED=""
  AP_ORIG_NM_STATE=""
  IP_FORWARD_OLD=""
  IPTABLES_NAT_ADDED=0
  IPTABLES_FWD1_ADDED=0
  IPTABLES_FWD2_ADDED=0
  IPTABLES_MSS_ADDED=0
  CONTROLLER_PID=""
  CONTROLLER_STARTTIME=""

  # shellcheck source=/dev/null
  source "$state_file"
  STATE_FILE="$state_file"
}

stop_state_file() {
  local state_file="$1"
  local stopped=0

  if ! load_state_file "$state_file"; then
    return 1
  fi

  if tracked_controller_running; then
    echo "Stopping tracked wifiAP controller for ${AP_IFACE:-unknown}..."
    kill "$CONTROLLER_PID" 2>/dev/null || true

    for _ in {1..40}; do
      [[ ! -e "$state_file" ]] && stopped=1 && break
      tracked_controller_running || break
      sleep 0.25
    done

    if [[ $stopped -eq 1 || ! -e "$state_file" ]]; then
      echo "Stopped AP on ${AP_IFACE:-unknown}."
      return 0
    fi

    load_state_file "$state_file" || true
  fi

  echo "Cleaning tracked AP resources for ${AP_IFACE:-unknown}..."
  cleanup_resources
  echo "Stopped AP on ${AP_IFACE:-unknown}."
}

stop_untracked_child_by_conf_prefix() {
  local process_name="$1"
  local conf_prefix="$2"
  local proc
  local pid
  local cmdline
  local matched=1

  for proc in /proc/[0-9]*; do
    [[ -d "$proc" ]] || continue
    pid="${proc##*/}"
    cmdline="$(pid_cmdline "$pid")"
    [[ "$cmdline" == *"$process_name"* && "$cmdline" == *"$conf_prefix"* ]] || continue
    kill "$pid" 2>/dev/null || true
    if ! wait_for_pid_exit "$pid"; then
      cmdline="$(pid_cmdline "$pid")"
      if [[ "$cmdline" == *"$process_name"* && "$cmdline" == *"$conf_prefix"* ]]; then
        kill -KILL "$pid" 2>/dev/null || true
        wait_for_pid_exit "$pid" || true
      fi
    fi
    matched=0
  done

  return "$matched"
}

UNTRACKED_IFACES=()

add_untracked_iface() {
  local iface="$1"
  local existing

  [[ -n "$iface" ]] || return 0
  [[ "$iface" == */* ]] && return 0

  for existing in "${UNTRACKED_IFACES[@]}"; do
    [[ "$existing" == "$iface" ]] && return 0
  done

  UNTRACKED_IFACES+=("$iface")
}

collect_untracked_ifaces() {
  local proc
  local pid
  local cmdline
  local file
  local base
  local iface
  local nullglob_was_set=0

  UNTRACKED_IFACES=()

  for proc in /proc/[0-9]*; do
    [[ -d "$proc" ]] || continue
    pid="${proc##*/}"
    cmdline="$(pid_cmdline "$pid")"

    if [[ "$cmdline" =~ /tmp/hostapd-([^[:space:]/]+)-[A-Za-z0-9]+\.conf ]]; then
      add_untracked_iface "${BASH_REMATCH[1]}"
    fi

    if [[ "$cmdline" =~ /tmp/dnsmasq-([^[:space:]/]+)-[A-Za-z0-9]+\.conf ]]; then
      add_untracked_iface "${BASH_REMATCH[1]}"
    fi
  done

  shopt -q nullglob && nullglob_was_set=1
  shopt -s nullglob
  for file in /tmp/hostapd-*.conf /tmp/dnsmasq-*.conf; do
    base="${file##*/}"
    iface="${base#hostapd-}"
    iface="${iface#dnsmasq-}"
    iface="${iface%-*.conf}"
    add_untracked_iface "$iface"
  done
  [[ $nullglob_was_set -eq 0 ]] && shopt -u nullglob
}

untracked_conf_exists() {
  local iface="$1"
  local files=()
  local nullglob_was_set=0

  shopt -q nullglob && nullglob_was_set=1
  shopt -s nullglob
  files=(/tmp/hostapd-"$iface"-*.conf /tmp/dnsmasq-"$iface"-*.conf)
  [[ $nullglob_was_set -eq 0 ]] && shopt -u nullglob

  [[ ${#files[@]} -gt 0 ]]
}

stop_untracked_iface() {
  local iface="$1"
  local report_missing="${2:-1}"
  local killed=0
  local had_conf=0

  if untracked_conf_exists "$iface"; then
    had_conf=1
  fi

  if stop_untracked_child_by_conf_prefix hostapd "/tmp/hostapd-${iface}-"; then
    killed=1
  fi

  if stop_untracked_child_by_conf_prefix dnsmasq "/tmp/dnsmasq-${iface}-"; then
    killed=1
  fi

  if [[ $killed -eq 0 ]]; then
    if [[ $had_conf -eq 0 && "$report_missing" -eq 1 ]]; then
      echo "No wifiAP-created AP found for $iface. Resetting interface anyway."
    fi
  fi

  restore_ap_interface "$iface" 1

  rm -f /tmp/hostapd-"$iface"-*.conf
  rm -f /tmp/dnsmasq-"$iface"-*.conf
  if [[ $killed -eq 1 || $had_conf -eq 1 ]]; then
    echo "Stopped untracked wifiAP resources on $iface."
  fi
  return 0
}

stop_all_untracked_ifaces() {
  local iface
  local stopped=0

  collect_untracked_ifaces

  for iface in "${UNTRACKED_IFACES[@]}"; do
    if stop_untracked_iface "$iface" 0; then
      stopped=1
    fi
  done

  [[ $stopped -eq 1 ]]
}

stop_tracked_aps() {
  local target_iface="$1"
  local files=()
  local nullglob_was_set=0
  local state_file
  local stopped=0

  if [[ -n "$target_iface" ]]; then
    validate_state_iface "$target_iface"
    state_file="$(state_file_for_iface "$target_iface")"
    if [[ ! -f "$state_file" ]]; then
      stop_untracked_iface "$target_iface" 1 || true
      return 0
    fi
    stop_state_file "$state_file" || true
    return 0
  fi

  if [[ -d "$STATE_DIR" ]]; then
    shopt -q nullglob && nullglob_was_set=1
    shopt -s nullglob
    files=("$STATE_DIR"/*.state)
    [[ $nullglob_was_set -eq 0 ]] && shopt -u nullglob

    for state_file in "${files[@]}"; do
      stop_state_file "$state_file" || true
      stopped=1
    done
  fi

  if stop_all_untracked_ifaces; then
    stopped=1
  fi

  if [[ $stopped -eq 0 ]]; then
    echo "No wifiAP-created APs found."
  fi
}

write_state() {
  local tmp_file

  [[ -n "$STATE_FILE" ]] || return 0

  ensure_state_dir
  tmp_file="${STATE_FILE}.$$"
  {
    printf 'CONTROLLER_PID=%q\n' "$CONTROLLER_PID"
    printf 'CONTROLLER_STARTTIME=%q\n' "$CONTROLLER_STARTTIME"
    printf 'AP_IFACE=%q\n' "$AP_IFACE"
    printf 'WAN_IFACE=%q\n' "$WAN_IFACE"
    printf 'AP_ADDR=%q\n' "$AP_ADDR"
    printf 'AP_CIDR=%q\n' "$AP_CIDR"
    printf 'AP_SUBNET=%q\n' "$AP_SUBNET"
    printf 'HOSTAPD_CONF=%q\n' "$HOSTAPD_CONF"
    printf 'DNSMASQ_CONF=%q\n' "$DNSMASQ_CONF"
    printf 'HOSTAPD_PID=%q\n' "$HOSTAPD_PID"
    printf 'DNSMASQ_PID=%q\n' "$DNSMASQ_PID"
    printf 'NM_MANAGED_CHANGED=%q\n' "$NM_MANAGED_CHANGED"
    printf 'NM_PREV_CONN=%q\n' "$NM_PREV_CONN"
    printf 'AP_ORIG_CAPTURED=%q\n' "$AP_ORIG_CAPTURED"
    printf 'AP_ORIG_LINK_UP=%q\n' "$AP_ORIG_LINK_UP"
    printf 'AP_ORIG_TYPE=%q\n' "$AP_ORIG_TYPE"
    printf 'AP_ORIG_IPV4_ADDRS=%q\n' "$AP_ORIG_IPV4_ADDRS"
    printf 'AP_ORIG_IPV6_ADDRS=%q\n' "$AP_ORIG_IPV6_ADDRS"
    printf 'AP_ORIG_NM_MANAGED=%q\n' "$AP_ORIG_NM_MANAGED"
    printf 'AP_ORIG_NM_STATE=%q\n' "$AP_ORIG_NM_STATE"
    printf 'IP_FORWARD_OLD=%q\n' "$IP_FORWARD_OLD"
    printf 'IPTABLES_NAT_ADDED=%q\n' "$IPTABLES_NAT_ADDED"
    printf 'IPTABLES_FWD1_ADDED=%q\n' "$IPTABLES_FWD1_ADDED"
    printf 'IPTABLES_FWD2_ADDED=%q\n' "$IPTABLES_FWD2_ADDED"
    printf 'IPTABLES_MSS_ADDED=%q\n' "$IPTABLES_MSS_ADDED"
  } > "$tmp_file"
  chmod 600 "$tmp_file"
  mv -f "$tmp_file" "$STATE_FILE"
}

if [[ -n "$AP_IFACE" ]]; then
  validate_state_iface "$AP_IFACE"
fi

if [[ $KILL_MODE -eq 1 ]]; then
  stop_tracked_aps "$AP_IFACE"
  exit 0
fi

if [[ -z "$AP_IFACE" ]]; then
  echo "AP interface is required." >&2
  usage
  exit 1
fi

if [[ -n "$PASSWORD" ]]; then
  if (( ${#PASSWORD} < 8 || ${#PASSWORD} > 63 )); then
    echo "Password must be between 8 and 63 characters." >&2
    exit 1
  fi
fi

STATE_FILE="$(state_file_for_iface "$AP_IFACE")"
CONTROLLER_STARTTIME="$(process_starttime "$$")"
HOSTAPD_CONF="$(mktemp /tmp/hostapd-${AP_IFACE}-XXXX.conf)"

trap cleanup EXIT
trap 'trap - EXIT; cleanup; exit 130' INT
trap 'trap - EXIT; cleanup; exit 143' TERM
write_state

require_cmd() {
  local cmd="$1"
  local pkg_hint="$2"

  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "Missing command '$cmd'. Install it with: apt install -y $pkg_hint" >&2
    exit 1
  fi
}

require_iface() {
  local iface="$1"
  if ! ip link show "$iface" >/dev/null 2>&1; then
    echo "Interface '$iface' does not exist." >&2
    exit 1
  fi
}

require_cmd hostapd hostapd
require_cmd dnsmasq dnsmasq
require_cmd ip iproute2

if ! [[ "$CHANNEL" =~ ^[0-9]+$ ]]; then
  echo "Channel must be numeric." >&2
  exit 1
fi

require_iface "$AP_IFACE"
capture_original_iface_state "$AP_IFACE"

if [[ -n "$WAN_IFACE" ]]; then
  require_cmd iptables iptables
  require_cmd sysctl procps
  require_iface "$WAN_IFACE"

  if [[ "$AP_IFACE" == "$WAN_IFACE" ]]; then
    echo "AP interface and WAN interface must be different." >&2
    exit 1
  fi
fi

cat > "$HOSTAPD_CONF" <<EOF
interface=$AP_IFACE
driver=nl80211
ssid=$SSID
country_code=$COUNTRY
ieee80211d=1
hw_mode=g
channel=$CHANNEL
beacon_int=100
dtim_period=2
ignore_broadcast_ssid=0
macaddr_acl=0
disassoc_low_ack=0
EOF

if [[ -n "$PASSWORD" ]]; then
  cat >> "$HOSTAPD_CONF" <<EOF
auth_algs=1
wpa=2
wpa_passphrase=$PASSWORD
wpa_key_mgmt=WPA-PSK
wpa_pairwise=TKIP CCMP
rsn_pairwise=CCMP
EOF
else
  echo "auth_algs=1" >> "$HOSTAPD_CONF"
fi

if [[ $LEGACY_MODE -eq 0 ]]; then
  cat >> "$HOSTAPD_CONF" <<EOF
wmm_enabled=1
ieee80211n=1
ht_capab=[HT20][SHORT-GI-20][DSSS_CCK-40]
EOF
fi

echo "Preparing AP interface $AP_IFACE..."
if command -v nmcli >/dev/null 2>&1; then
  NM_PREV_CONN="$(nmcli -t -f NAME,DEVICE connection show --active 2>/dev/null | awk -F: -v d="$AP_IFACE" '$2==d{print $1; exit}' || true)"
  if [[ -n "$NM_PREV_CONN" ]]; then
    echo "Saved previous NM connection on $AP_IFACE: $NM_PREV_CONN"
  fi
  nmcli device disconnect "$AP_IFACE" >/dev/null 2>&1 || true
  nmcli device set "$AP_IFACE" managed no >/dev/null 2>&1 || true
  NM_MANAGED_CHANGED=1
  write_state
fi

if command -v rfkill >/dev/null 2>&1; then
  rfkill unblock wifi >/dev/null 2>&1 || true
  rfkill unblock all >/dev/null 2>&1 || true
fi

pkill -f "wpa_supplicant.*${AP_IFACE}" 2>/dev/null || true

ip link set "$AP_IFACE" down
if command -v iw >/dev/null 2>&1; then
  iw reg set "$COUNTRY" >/dev/null 2>&1 || true
  iw dev "$AP_IFACE" set type managed >/dev/null 2>&1 || true
fi
ip addr flush dev "$AP_IFACE"
ip addr add "${AP_ADDR}/${AP_CIDR}" dev "$AP_IFACE"
ip link set "$AP_IFACE" up

echo "Starting DHCP on $AP_IFACE..."
DNSMASQ_CONF="$(mktemp /tmp/dnsmasq-${AP_IFACE}-XXXX.conf)"
write_state
cat > "$DNSMASQ_CONF" <<EOF
interface=$AP_IFACE
bind-dynamic
domain-needed
bogus-priv
no-resolv
server=1.1.1.1
server=8.8.8.8
dhcp-range=$DHCP_START,$DHCP_END,255.255.255.0,12h
dhcp-authoritative
dhcp-option=3,$AP_ADDR
dhcp-option=6,$AP_ADDR
log-dhcp
EOF

dnsmasq --conf-file="$DNSMASQ_CONF" --no-daemon --log-facility=- &
DNSMASQ_PID="$!"
write_state

if [[ -n "$WAN_IFACE" ]]; then
  echo "Configuring NAT from $WAN_IFACE to $AP_IFACE..."
  IP_FORWARD_OLD="$(cat /proc/sys/net/ipv4/ip_forward)"
  write_state
  sysctl -w net.ipv4.ip_forward=1 >/dev/null

  iptables -t nat -A POSTROUTING -s "$AP_SUBNET" -o "$WAN_IFACE" -j MASQUERADE
  IPTABLES_NAT_ADDED=1
  write_state
  iptables -A FORWARD -i "$WAN_IFACE" -o "$AP_IFACE" -m state --state RELATED,ESTABLISHED -j ACCEPT
  IPTABLES_FWD1_ADDED=1
  write_state
  iptables -A FORWARD -i "$AP_IFACE" -o "$WAN_IFACE" -j ACCEPT
  IPTABLES_FWD2_ADDED=1
  write_state
  iptables -t mangle -A FORWARD -o "$WAN_IFACE" -p tcp --tcp-flags SYN,RST SYN -j TCPMSS --clamp-mss-to-pmtu
  IPTABLES_MSS_ADDED=1
  write_state

fi

if [[ -n "$WAN_IFACE" ]]; then
  echo "Clients will get gateway $AP_ADDR and Internet through $WAN_IFACE."
else
  echo "Local-only mode: connect to '$SSID' and access this device at $AP_ADDR."
fi

if [[ -n "$PASSWORD" ]]; then
  echo "Starting WPA2 AP '$SSID' on $AP_IFACE, channel $CHANNEL..."
else
  echo "Starting open AP '$SSID' on $AP_IFACE, channel $CHANNEL..."
fi
hostapd "$HOSTAPD_CONF" &
HOSTAPD_PID="$!"
write_state

wait "$HOSTAPD_PID"
