#!/usr/bin/env bash
set -euo pipefail

ZSH_CONFIG_DIR="${ZSH_CONFIG_DIR:-$HOME/.config/zsh}"
ALIASES_FILE="$ZSH_CONFIG_DIR/aliases.zsh"

# Pide al usuario el nombre del alias y el comando a ejecutar
read -r -p "Ingresa el nombre del alias: " alias_name

if [[ ! "$alias_name" =~ ^[A-Za-z0-9_.-]+$ ]]; then
    echo "Nombre de alias inválido: usa letras, números, punto, guion o guion bajo." >&2
    exit 1
fi

read -r -p "Ingresa el comando que quieres asignar al alias: " command

mkdir -p "$ZSH_CONFIG_DIR"
touch "$ALIASES_FILE"

# %q conserva correctamente espacios y comillas y es válido en Zsh.
printf -v alias_definition 'alias %s=%q' "$alias_name" "$command"
printf '%s\n' "$alias_definition" >> "$ALIASES_FILE"

# Conserva el instalador histórico, pero ahora apunta al archivo modular.
printf "printf '%%s\\n' %q >> %q\n" "$alias_definition" "$ALIASES_FILE" >> "$HOME/.aliaszsh"

echo "Alias configurado en $ALIASES_FILE."
