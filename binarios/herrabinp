#!/usr/bin/env bash

omitir=false
omitirPreguntas=false

mostrar_uso() {
    echo "Usage: $0 [-o] [-p]"
    echo "  -o    Omit install/update flow and show todob questions only."
    echo "  -p    Install herrabin tools and update binaries without questions."
    exit 1
}

while getopts "op" opt; do
    case $opt in
        o)
            omitir=true
            ;;
        p)
            omitirPreguntas=true
            ;;
        \?)
            echo "Opción inválida: -$OPTARG" >&2
            mostrar_uso
            ;;
    esac
done

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd -P)"
todob_bin=""

if [[ -x "${script_dir}/todob" ]]; then
    todob_bin="${script_dir}/todob"
elif command -v todob >/dev/null 2>&1; then
    todob_bin="$(command -v todob)"
else
    echo "todob not found; cannot continue." >&2
    exit 1
fi

if [[ $omitir == true && $omitirPreguntas == true ]]; then
    exit 0
elif [[ $omitir == true ]]; then
    exec "$todob_bin" -p
elif [[ $omitirPreguntas == true ]]; then
    exec "$todob_bin" -x
else
    exec "$todob_bin" -x -a
fi
