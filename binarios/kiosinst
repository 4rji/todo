#!/usr/bin/env bash

set -e

USER_NAME="${SUDO_USER:-$USER}"
USER_HOME="$(getent passwd "$USER_NAME" | cut -d: -f6)"
URL="https://google.com"
OUTPUT="HDMI-1"

echo "[*] User: $USER_NAME"
echo "[*] Home: $USER_HOME"

echo "[*] Installing packages..."
sudo apt update
sudo apt install -y --no-install-recommends \
  xserver-xorg \
  x11-xserver-utils \
  xinit \
  openbox \
  chromium \
  unclutter

echo "[*] Creating $USER_HOME/.xinitrc ..."

cat > "$USER_HOME/.xinitrc" <<EOF
#!/bin/sh

xset -dpms
xset s off
xset s noblank

xrandr --output $OUTPUT --rotate inverted

unclutter &

openbox-session &

chromium \\
  --kiosk \\
  --noerrdialogs \\
  --disable-infobars \\
  --incognito \\
  $URL
EOF

chmod +x "$USER_HOME/.xinitrc"
chown "$USER_NAME:$USER_NAME" "$USER_HOME/.xinitrc"

STARTX_LINE='[[ -z "$DISPLAY" && "$XDG_VTNR" = "1" ]] && startx'

echo "[*] Adding startx to shell profiles..."

for file in "$USER_HOME/.bash_profile" "$USER_HOME/.profile" "$USER_HOME/.zprofile"; do
  touch "$file"
  chown "$USER_NAME:$USER_NAME" "$file"

  if ! grep -Fq "$STARTX_LINE" "$file"; then
    cat >> "$file" <<EOF

# Start kiosk on tty1
$STARTX_LINE
EOF
  fi
done

echo "[*] Configuring tty1 autologin..."

sudo mkdir -p /etc/systemd/system/getty@tty1.service.d

sudo tee /etc/systemd/system/getty@tty1.service.d/override.conf > /dev/null <<EOF
[Service]
ExecStart=
ExecStart=-/sbin/agetty --autologin $USER_NAME --noclear %I \$TERM
EOF

sudo systemctl daemon-reload

echo
echo "[+] Done."
echo
echo "Reboot recommended:"
echo "sudo reboot"
echo
echo "To start kiosk manually:"
echo "startx"