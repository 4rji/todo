#!/bin/bash

set -e

URL="https://google.com"
OUTPUT="HDMI-1"

echo "[*] Installing packages..."

sudo apt update
sudo apt install -y --no-install-recommends \
  xserver-xorg \
  x11-xserver-utils \
  xinit \
  openbox \
  chromium \
  unclutter

echo "[*] Creating ~/.xinitrc ..."

cat > ~/.xinitrc <<EOF
#!/bin/sh

xset -dpms
xset s off
xset s noblank

xrandr --output $OUTPUT --rotate inverted

unclutter &

openbox-session &

chromium \\
  --kiosk \\
  --noerrdialogs \\
  --disable-infobars \\
  --incognito \\
  $URL
EOF

chmod +x ~/.xinitrc

echo "[*] Creating ~/.bash_profile ..."

cat > ~/.bash_profile <<'EOF'
[[ -z $DISPLAY && $XDG_VTNR -eq 1 ]] && startx
EOF

echo
echo "[+] Done."
echo
echo "Reboot recommended."
echo
echo "To start kiosk mode manually:"
echo
echo "startx"
