#!/usr/bin/env bash
set -euo pipefail

print_color() {
    local code=$1; shift
    printf '\e[1;%sm%s\e[0m\n' "$code" "$*"
}

usage() {
    cat <<EOF
Usage: $(basename "$0") <ip|host> [-u]
  -u    Tambien escanea UDP top-100 puertos despues del TCP (lento, requiere root)
EOF
    exit 1
}

ping_ip() {
    local ip=$1
    echo
    print_color 36 "Pinging IP: $ip"
    echo
    ping -c 1 -W 2 "$ip" || print_color 33 "Ping fallo, continuo igual"
}

determine_os() {
    local ip=$1 os_type
    os_type=$(timeout 5s whichsys "$ip" 2>/dev/null || echo "unknown")
    printf '\n\033[1;37m_________________________________________________________\033[0m\n\n'
    print_color 31 "$os_type"
    printf '\n\033[1;37m_________________________________________________________\033[0m\n\n'
    printf '%s\n' "$os_type" > OS-type
}

udp_scan() {
    local ip=$1
    printf '\n\033[1;37m_________________________________________________________\033[0m\n\n'
    print_color 35 "UDP top-100 scan (lento, paciencia)..."
    echo
    sudo nmap -sU --top-ports 100 --open -v -n "$ip" -oG allPortsUDP
}

udp=0
ip=""
for arg in "$@"; do
    case "$arg" in
        -u)        udp=1 ;;
        -h|--help) usage ;;
        -*)        print_color 31 "Flag desconocido: $arg"; usage ;;
        *)         ip=$arg ;;
    esac
done

[[ -z "$ip" ]] && usage
[[ "$ip" =~ ^[A-Za-z0-9.:-]+$ ]] || { print_color 31 "IP/host invalido"; exit 1; }

if (( udp == 0 )); then
    print_color 33 "[tip] Existe flag -u para incluir scan UDP top-100. Ej: $(basename "$0") $ip -u"
fi

ping_ip "$ip"
determine_os "$ip"

if ! expo1 "$ip"; then
    print_color 31 "expo1 fallo. Aborto."
    exit 1
fi

expo2

if (( udp )); then
    udp_scan "$ip"
fi
