#!/usr/bin/env bash
set -euo pipefail

print_color() {
    local code=$1; shift
    printf '\e[1;%sm%s\e[0m\n' "$code" "$*"
}

usage() { echo "Usage: $(basename "$0") <ip|host>"; exit 1; }

ping_ip() {
    local ip=$1
    echo
    print_color 36 "Pinging IP: $ip"
    echo
    ping -c 1 -W 2 "$ip" || print_color 33 "Ping fallo, continuo igual"
}

determine_os() {
    local ip=$1 os_type
    os_type=$(timeout 5s whichsys "$ip" 2>/dev/null || echo "unknown")
    printf '\n\033[1;37m_________________________________________________________\033[0m\n\n'
    print_color 31 "$os_type"
    printf '\n\033[1;37m_________________________________________________________\033[0m\n\n'
    printf '%s\n' "$os_type" > OS-type
}

[[ $# -eq 0 ]] && usage
ip=$1

[[ "$ip" =~ ^[A-Za-z0-9.:-]+$ ]] || { print_color 31 "IP/host invalido"; exit 1; }

ping_ip "$ip"
determine_os "$ip"

if ! expo1 "$ip"; then
    print_color 31 "expo1 fallo. Aborto."
    exit 1
fi

expo2
