#!/usr/bin/env bash
set -euo pipefail

CONFIG="$HOME/.ssh/config"

c_reset=$'\033[0m'
c_bold=$'\033[1m'
c_cyan=$'\033[96m'
c_yellow=$'\033[93m'
c_green=$'\033[92m'
c_red=$'\033[91m'
c_blue=$'\033[94m'

print_separator() {
    printf '\n%s%s_________________________________________________________%s\n\n' "$c_cyan" "$c_bold" "$c_reset"
}

prompt_color() {
    printf '%s%s%s%s' "$1" "$c_bold" "$2" "$c_reset"
}

usage() {
    cat <<EOF
Uso:
  $(basename "$0")                          # modo interactivo
  $(basename "$0") user@host                # agrega directo, puerto 22
  $(basename "$0") user@host nombre         # agrega directo con alias custom
  $(basename "$0") user@host:2222           # agrega con puerto custom
  $(basename "$0") host                     # sin user, puerto 22
  $(basename "$0") user@host:port nombre    # alias custom (default = host)

Si no se especifica puerto, se usa 22.
EOF
    exit "${1:-1}"
}

ensure_config() {
    mkdir -p "$HOME/.ssh"
    chmod 700 "$HOME/.ssh"
    if [[ ! -f "$CONFIG" ]]; then
        : > "$CONFIG"
        chmod 600 "$CONFIG"
    fi
}

append_host() {
    local name="$1" host="$2" user="$3" port="$4"
    {
        printf '\nHost %s\n' "$name"
        printf '\tHostname %s\n' "$host"
        [[ -n "$user" ]] && printf '\tUser %s\n' "$user"
        printf '\tPort %s\n' "$port"
    } >> "$CONFIG"
    printf '%s%sAgregado:%s Host=%s Hostname=%s User=%s Port=%s\n' \
        "$c_green" "$c_bold" "$c_reset" "$name" "$host" "${user:-<ninguno>}" "$port"
}

parse_target() {
    local arg="$1"
    local user="" rest="" host="" port="22"

    if [[ "$arg" == *"@"* ]]; then
        user="${arg%%@*}"
        rest="${arg#*@}"
    else
        rest="$arg"
    fi

    if [[ "$rest" == *":"* ]]; then
        host="${rest%%:*}"
        port="${rest##*:}"
    else
        host="$rest"
    fi

    if [[ -z "$host" ]]; then
        printf '%sError: host vacío.%s\n' "$c_red" "$c_reset" >&2
        return 1
    fi
    if ! [[ "$port" =~ ^[0-9]+$ ]] || (( port < 1 || port > 65535 )); then
        printf '%sError: puerto inválido "%s".%s\n' "$c_red" "$port" "$c_reset" >&2
        return 1
    fi

    printf '%s\n%s\n%s\n' "$user" "$host" "$port"
}

interactive_mode() {
    print_separator
    printf '%s%sIngresá los detalles del host:%s\n' "$c_yellow" "$c_bold" "$c_reset"

    prompt_color "$c_green" "Nombre del host (alias): "
    read -r host_name

    prompt_color "$c_red" "Hostname o IP: "
    read -r host_address

    prompt_color "$c_blue" "Usuario SSH (opcional): "
    read -r user_name

    prompt_color "$c_blue" "Puerto SSH (vacío = 22): "
    read -r host_port
    [[ -z "$host_port" ]] && host_port=22

    if [[ -z "$host_name" || -z "$host_address" ]]; then
        printf '%sFaltan datos obligatorios (nombre y hostname).%s\n' "$c_red" "$c_reset" >&2
        exit 1
    fi
    if ! [[ "$host_port" =~ ^[0-9]+$ ]] || (( host_port < 1 || host_port > 65535 )); then
        printf '%sPuerto inválido.%s\n' "$c_red" "$c_reset" >&2
        exit 1
    fi

    append_host "$host_name" "$host_address" "$user_name" "$host_port"
}

cli_mode() {
    if (( $# > 2 )); then
        printf '%sError: demasiados argumentos.%s\n' "$c_red" "$c_reset" >&2
        usage 1
    fi

    local target="$1"
    local name="${2:-}"
    local parsed user host port
    parsed="$(parse_target "$target")" || exit 1
    user="$(printf '%s' "$parsed" | sed -n '1p')"
    host="$(printf '%s' "$parsed" | sed -n '2p')"
    port="$(printf '%s' "$parsed" | sed -n '3p')"
    [[ -z "$name" ]] && name="$host"
    if [[ "$name" == *[[:space:]]* ]]; then
        printf '%sError: el alias no puede contener espacios.%s\n' "$c_red" "$c_reset" >&2
        exit 1
    fi
    append_host "$name" "$host" "$user" "$port"
}

main() {
    case "${1:-}" in
        -h|--help) usage 0 ;;
    esac

    ensure_config

    if [[ $# -ge 1 ]]; then
        cli_mode "$@"
    else
        interactive_mode
    fi

    print_separator
    printf '%s%sContenido de %s:%s\n' "$c_yellow" "$c_bold" "$CONFIG" "$c_reset"
    cat "$CONFIG"
    print_separator
}

main "$@"

