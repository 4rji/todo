#!/usr/bin/env bash

# Direct mode: brillo <number>
if [ -n "$1" ]; then
    echo "$1" | sudo tee /sys/class/backlight/*/brightness
    exit 0
fi

# Colors
CYAN='\033[1;36m'
YELLOW='\033[1;33m'
GREEN='\033[1;32m'
WHITE='\033[1;37m'
DIM='\033[0;90m'
RESET='\033[0m'

# Interactive mode
BACKLIGHT=$(echo /sys/class/backlight/*)
BRIGHTNESS_FILE="$BACKLIGHT/brightness"
MAX_FILE="$BACKLIGHT/max_brightness"

if [ ! -f "$BRIGHTNESS_FILE" ]; then
    echo -e "${YELLOW}No backlight found at /sys/class/backlight/${RESET}"
    exit 1
fi

MAX=$(cat "$MAX_FILE")
CURRENT=$(cat "$BRIGHTNESS_FILE")
STEP=20

sudo -v

echo ""
echo -e "  ${CYAN}Brightness Control${RESET}  ${DIM}← → to adjust  |  q / Enter to quit${RESET}"
echo ""

while true; do
    PCT=$((CURRENT * 100 / MAX))
    FILLED=$((PCT / 5))

    BAR=""
    for ((i=0; i<20; i++)); do
        if [[ $i -lt $FILLED ]]; then
            BAR+="${YELLOW}█${RESET}"
        else
            BAR+="${DIM}░${RESET}"
        fi
    done

    printf "\r  ${WHITE}[${RESET}%b${WHITE}]${RESET}  ${GREEN}%3d%%${RESET}  ${DIM}(%d / %d)${RESET}   " \
        "$BAR" "$PCT" "$CURRENT" "$MAX"

    IFS= read -rsn1 key

    if [[ $key == $'\x1b' ]]; then
        read -rsn2 -t 0.1 rest
        key="$key$rest"
    fi

    case "$key" in
        $'\x1b[C'|$'\x1b[A')  # → or ↑
            CURRENT=$((CURRENT + STEP))
            [[ $CURRENT -gt $MAX ]] && CURRENT=$MAX
            echo "$CURRENT" | sudo tee "$BRIGHTNESS_FILE" > /dev/null
            ;;
        $'\x1b[D'|$'\x1b[B')  # ← or ↓
            CURRENT=$((CURRENT - STEP))
            [[ $CURRENT -lt 0 ]] && CURRENT=0
            echo "$CURRENT" | sudo tee "$BRIGHTNESS_FILE" > /dev/null
            ;;
        q|''|$'\n')
            echo ""
            echo -e "  ${DIM}Brightness set to ${GREEN}${CURRENT}${RESET}"
            echo ""
            break
            ;;
    esac
done
