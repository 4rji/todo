#!/usr/bin/env bash
# mibebe — monitor de conexiones activas (SSH + sockets) con kill interactivo.
# Cross-platform: Linux y macOS. Soporta watch mode, fzf y JSON.

set -uo pipefail

# ─── Colores ────────────────────────────────────────────────────────────────
amarillo='\033[1;33m'
azul='\033[0;34m'
rojo='\033[0;31m'
cafe='\033[0;33m'
verde='\033[0;32m'
magenta='\033[1;35m'
cyan='\033[0;36m'
gris='\033[1;30m'
fin='\033[0m'

# ─── Defaults ───────────────────────────────────────────────────────────────
ACTION="interactive"   # interactive | show | killall | json
WATCH=0
WATCH_INTERVAL=3
TOP_N=5
NO_LISTENERS=0
USE_FZF="auto"         # auto | no
PROMPT_TIMEOUT=6
EXCLUDE_RE='tailscale'
DEADMAN_SEC=""

# ─── Helpers ────────────────────────────────────────────────────────────────
have() { command -v "$1" >/dev/null 2>&1; }

usage() {
    cat <<EOF
Uso: mibebe [opciones]

  -n           Solo mostrar (sin prompt de kill)
  -k           Matar TODAS las conexiones (sin preguntar)
  -j           Salida JSON
  -w           Watch mode (refresh continuo, Ctrl+C para salir)
  -i SEG       Intervalo del watch mode (default: ${WATCH_INTERVAL}s)
  -K SEG       Deadman: mostrar, esperar SEG seg, killall (combina con -w para loop)
  -t N         Top N procesos a mostrar (default: ${TOP_N})
  -L           No listar puertos en LISTEN
  -F           No usar fzf aunque esté instalado
  -e REGEX     Regex de procesos a excluir (default: '${EXCLUDE_RE}')
  -h           Esta ayuda

Ejemplos:
  mibebe                  # interactivo (default)
  mibebe -n               # solo monitor, no toca nada
  mibebe -w -i 2          # watch cada 2s
  mibebe -j | jq          # JSON para automatizar
  mibebe -k               # cerrar todas (cuidado)
  mibebe -K 13            # deadman: mostrar, esperar 13s, killall, salir
  mibebe -K 13 -w         # loop deadman infinito (ex-pssc)
EOF
}

print_sep()   { printf "\n${verde}_________________________________________________________${fin}\n\n"; }
print_sep_r() { printf "\n${rojo}_________________________________________________________${fin}\n\n"; }
print_sep_b() { printf "\n${azul}_________________________________________________________${fin}\n\n"; }

detect_os() {
    case "$(uname -s)" in
        Linux)  OS=linux ;;
        Darwin) OS=darwin ;;
        *)      OS=other ;;
    esac
}

# IP privada / loopback / link-local / wildcard.
is_private_ip() {
    local ip=$1
    case "$ip" in
        10.*|127.*|192.168.*|169.254.*|0.0.0.0*|'*') return 0 ;;
        172.1[6-9].*|172.2[0-9].*|172.3[0-1].*)     return 0 ;;
        ::1|::|fe80:*|fc*|fd*)                       return 0 ;;
        *) return 1 ;;
    esac
}

# Saca la IP de "ip:port" o "[ipv6]:port".
extract_ip() {
    local s=$1
    if [[ "$s" == \[*\]* ]]; then
        s="${s#[}"
        s="${s%%]*}"
        printf '%s' "$s"
    else
        printf '%s' "${s%:*}"
    fi
}

# ─── SSH section ────────────────────────────────────────────────────────────
ssh_listen_port() {
    local cfg port=""
    for cfg in /etc/ssh/sshd_config /private/etc/ssh/sshd_config; do
        [ -r "$cfg" ] || continue
        port=$(awk '/^Port[[:space:]]/{print $2; exit}' "$cfg" 2>/dev/null || true)
        [ -n "$port" ] && { printf '%s' "$port"; return; }
    done
    printf '22'
}

ssh_section() {
    local port active
    port=$(ssh_listen_port)
    echo -e "${amarillo}Puerto SSH (sshd_config): ${port}${fin}"

    active=$(get_connections | awk -F'|' 'tolower($1) ~ /sshd?$/' | wc -l | tr -d ' ')
    if [ "${active:-0}" -gt 0 ]; then
        echo -e "${rojo}ALERTA: ${active} conexión(es) SSH activa(s)${fin}"
    else
        echo -e "${verde}Sin conexiones SSH activas${fin}"
    fi
}

# ─── Listeners ──────────────────────────────────────────────────────────────
listeners_section() {
    [ "$NO_LISTENERS" -eq 1 ] && return 0
    echo -e "${verde}Puertos escuchando${fin} ${magenta}(lsof -i -nP)${fin}"
    sudo lsof -i -nP 2>/dev/null | awk 'NR==1 || /LISTEN|UDP/' || true
}

# ─── Núcleo: lista de conexiones ESTABLISHED ────────────────────────────────
# Formato: cmd|pid|user|proto|local|remote
get_connections() {
    sudo lsof -i -nP 2>/dev/null | awk -v excl="$EXCLUDE_RE" '
        NR == 1 { next }
        /ESTABLISHED/ {
            cmd=$1; pid=$2; user=$3; proto=$8; addr=$9;
            if (excl != "" && tolower($0) ~ tolower(excl)) next;
            n = split(addr, a, "->");
            local  = (n >= 1 ? a[1] : "");
            remote = (n >= 2 ? a[2] : "");
            print cmd "|" pid "|" user "|" proto "|" local "|" remote;
        }' || true
}

# ─── Top N procesos ─────────────────────────────────────────────────────────
top_processes() {
    local rows
    rows=$(get_connections | awk -F'|' 'NF{print $1}' | sort | uniq -c | sort -rn | head -n "$TOP_N")
    if [ -z "$rows" ]; then
        echo -e "${gris}(sin procesos con conexiones)${fin}"
        return
    fi
    echo -e "${cyan}Top ${TOP_N} procesos con más conexiones:${fin}"
    printf '%s\n' "$rows" | awk -v c="$amarillo" -v f="$fin" '{ printf "  %s%5d%s  %s\n", c, $1, f, $2 }'
}

# ─── Tabla de conexiones ────────────────────────────────────────────────────
# Imprime tabla y devuelve 1 si vacío.
show_connections_table() {
    local conns
    conns=$(get_connections)
    if [ -z "$conns" ]; then
        echo -e "${verde}Sin conexiones establecidas${fin}"
        return 1
    fi

    printf "${cafe}%-3s %-12s %-7s %-10s %-30s %-30s %s${fin}\n" \
        "#" "CMD" "PID" "USER" "LOCAL" "REMOTE" "TIPO"

    local i=1 cmd pid user proto local remote rip color label
    while IFS='|' read -r cmd pid user proto local remote; do
        [ -z "${cmd:-}" ] && continue
        rip=$(extract_ip "$remote")
        if is_private_ip "$rip"; then
            color=$verde; label="PRIV"
        else
            color=$rojo;  label="PUB "
        fi
        printf "${color}%-3d %-12.12s %-7s %-10.10s %-30.30s %-30.30s %s${fin}\n" \
            "$i" "$cmd" "$pid" "$user" "$local" "$remote" "$label"
        i=$((i + 1))
    done <<< "$conns"
}

# ─── Salida JSON ────────────────────────────────────────────────────────────
json_output() {
    local first=1 cmd pid user proto local remote rip kind
    printf '{\n  "connections": [\n'
    while IFS='|' read -r cmd pid user proto local remote; do
        [ -z "${cmd:-}" ] && continue
        rip=$(extract_ip "$remote")
        if is_private_ip "$rip"; then kind=private; else kind=public; fi
        [ "$first" -eq 0 ] && printf ',\n'
        printf '    {"cmd":"%s","pid":%s,"user":"%s","proto":"%s","local":"%s","remote":"%s","kind":"%s"}' \
            "$cmd" "$pid" "$user" "$proto" "$local" "$remote" "$kind"
        first=0
    done <<< "$(get_connections)"
    printf '\n  ]\n}\n'
}

# ─── Kill ───────────────────────────────────────────────────────────────────
kill_pid() {
    local pid=$1
    if [ -z "$pid" ]; then
        echo -e "${rojo}PID vacío${fin}"
        return 1
    fi
    echo -e "Terminando PID ${magenta}${pid}${fin}..."
    if sudo kill -9 "$pid" 2>/dev/null; then
        echo -e "${verde}Proceso ${pid} terminado${fin}"
    else
        echo -e "${rojo}No se pudo terminar ${pid}${fin}"
    fi
}

kill_all() {
    local pids
    pids=$(get_connections | awk -F'|' 'NF{print $2}' | sort -u)
    if [ -z "$pids" ]; then
        echo -e "${verde}Nada que matar${fin}"
        return
    fi
    echo -e "${rojo}Cerrando todas las conexiones...${fin}"
    while read -r pid; do
        [ -z "$pid" ] && continue
        kill_pid "$pid"
    done <<< "$pids"
}

# ─── Picker (fzf si hay, si no número) ──────────────────────────────────────
picker_fzf() {
    local pick pid
    pick=$(get_connections | awk -F'|' '
        NF { printf "%-7s %-12s %-10s %-28s -> %s\n", $2, $1, $3, $5, $6 }' \
        | fzf --prompt="Matar conexión> " \
              --header="PID     CMD          USER       LOCAL                        -> REMOTE" \
              --height=40% --reverse || true)
    [ -z "$pick" ] && { echo -e "${cafe}Cancelado${fin}"; return; }
    pid=$(awk '{print $1}' <<< "$pick")
    kill_pid "$pid"
}

picker_numeric() {
    local conns opcion pid
    conns=$(get_connections)
    [ -z "$conns" ] && return

    echo ""
    echo -e "${amarillo}Número a cerrar, [s]=todas, Enter=salir (timeout ${PROMPT_TIMEOUT}s):${fin}"
    if ! read -r -t "$PROMPT_TIMEOUT" -n2 -p " >  " opcion; then
        echo
        echo -e "${cafe}Timeout${fin}"
        return
    fi
    echo

    if [[ "${opcion:-}" =~ ^[Ss]$ ]]; then
        kill_all
        return
    fi

    [ -z "${opcion:-}" ] && return

    if ! [[ "$opcion" =~ ^[0-9]+$ ]]; then
        echo -e "${rojo}Opción inválida${fin}"
        return
    fi

    pid=$(awk -F'|' -v n="$opcion" 'NR==n {print $2}' <<< "$conns")
    if [ -n "$pid" ]; then
        kill_pid "$pid"
    else
        echo -e "${rojo}Número fuera de rango${fin}"
    fi
}

interactive_kill() {
    if [ "$USE_FZF" = "auto" ] && have fzf && [ -t 0 ] && [ -t 1 ]; then
        picker_fzf
    else
        picker_numeric
    fi
}

# ─── Iteración principal (watch o one-shot) ─────────────────────────────────
main_iteration() {
    ssh_section
    print_sep
    listeners_section
    [ "$NO_LISTENERS" -eq 1 ] || print_sep_b
    show_connections_table || true
    print_sep_r
    top_processes
}

watch_loop() {
    trap 'echo; echo -e "${cafe}Saliendo de watch mode${fin}"; exit 0' INT TERM
    while true; do
        clear
        echo -e "${magenta}mibebe — watch (cada ${WATCH_INTERVAL}s, Ctrl+C salir)${fin}  ${gris}$(date)${fin}"
        print_sep
        main_iteration
        sleep "$WATCH_INTERVAL"
    done
}

# ─── Deadman: mostrar, sleep, killall ──────────────────────────────────────
deadman_once() {
    main_iteration
    print_sep_r
    echo -e "${rojo}DEADMAN: matando todo en ${DEADMAN_SEC}s (Ctrl+C aborta)${fin}"
    sleep "$DEADMAN_SEC"
    print_sep_r
    kill_all
}

deadman_loop() {
    trap 'echo; echo -e "${cafe}Saliendo deadman loop${fin}"; exit 0' INT TERM
    while true; do
        clear
        echo -e "${magenta}mibebe — deadman loop (kill cada ${DEADMAN_SEC}s, pausa ${WATCH_INTERVAL}s)${fin}  ${gris}$(date)${fin}"
        print_sep
        main_iteration
        echo -e "${rojo}DEADMAN: matando todo en ${DEADMAN_SEC}s${fin}"
        sleep "$DEADMAN_SEC"
        print_sep_r
        kill_all
        sleep "$WATCH_INTERVAL"
    done
}

# ─── Args ───────────────────────────────────────────────────────────────────
while getopts "nkjwi:K:t:LFe:h" opt; do
    case $opt in
        n) ACTION=show ;;
        k) ACTION=killall ;;
        j) ACTION=json ;;
        w) WATCH=1 ;;
        i) WATCH_INTERVAL=$OPTARG ;;
        K) DEADMAN_SEC=$OPTARG ;;
        t) TOP_N=$OPTARG ;;
        L) NO_LISTENERS=1 ;;
        F) USE_FZF=no ;;
        e) EXCLUDE_RE=$OPTARG ;;
        h) usage; exit 0 ;;
        *) usage; exit 1 ;;
    esac
done

detect_os

# ─── Despacho ───────────────────────────────────────────────────────────────
case "$ACTION" in
    json)
        json_output
        exit 0
        ;;
esac

if [ "$WATCH" -eq 1 ]; then
    if [ -n "$DEADMAN_SEC" ]; then
        deadman_loop
    else
        watch_loop
    fi
    exit 0
fi

if [ -n "$DEADMAN_SEC" ]; then
    deadman_once
    exit 0
fi

main_iteration

case "$ACTION" in
    interactive) interactive_kill ;;
    killall)     print_sep_r; kill_all ;;
    show)        : ;;  # ya mostró todo
esac
