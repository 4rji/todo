#!/usr/bin/env bash

# Colores
verde='\e[0;32m'
azul='\e[0;34m'
reset='\e[0m'
amarillo='\e[0;33m'

# Variables para controlar el flujo
mostrarPreguntas=false
mostrarBina=false
borrarBinarios=false
instalarHerramientas=false
bin_dir="/opt/4rji/bin"
platform="$(uname -s)"
arch="$(uname -m)"

case "$platform" in
    Linux)
        tmp_base="/dev/shm"
        actualizador="todou"
        if [[ "$arch" != "x86_64" && "$arch" != "amd64" ]]; then
            echo -e "${amarillo}Non-standard Linux architecture: ${arch}. Included binaries may not be compatible.${reset}"
        fi
        ;;
    Darwin)
        tmp_base="${TMPDIR:-/tmp}"
        actualizador="todoum"
        if [[ "$arch" != "arm64" && "$arch" != "aarch64" ]]; then
            echo -e "${amarillo}Non-standard macOS architecture: ${arch}. Included binaries may not be compatible.${reset}"
        fi
        ;;
    *)
        tmp_base="${TMPDIR:-/tmp}"
        actualizador=""
        echo -e "${amarillo}Unrecognized system: ${platform} ${arch}. Using temp in ${tmp_base}.${reset}"
        ;;
esac

if [[ ! -d "$tmp_base" ]]; then
    tmp_base="/tmp"
fi

# Show script usage
mostrar_uso() {
    echo "Usage: $0 [-p] [-a] [-c] [-x]"
    echo "  -p    Show interactive questions only."
    echo "  -a    Run full script (download binaries and show questions)."
    echo "  -c    Clean ${bin_dir}/* then run normal flow (download binaries)."
    echo "  -x    Install herrabin base tools for the detected OS, then update binaries."
    exit 1
}

# Verificar las opciones -p, -a, -c y -x
while getopts "pacx" opt; do
    case $opt in
        p)
            mostrarPreguntas=true
            ;;
        a)
            mostrarPreguntas=true
            mostrarBina=true
            ;;
        c)
            borrarBinarios=true
            ;;
        x)
            instalarHerramientas=true
            ;;
        \?)
            echo "Invalid option: -$OPTARG" >&2
            mostrar_uso
            ;;
    esac
done

# Shift para manejar correctamente los argumentos
shift $((OPTIND -1))

# Función para crear directorios temporales
mktem() {
    if [ -n "$1" ]; then
        new_dir=$(mktemp -d "${tmp_base}/tmp.$1.XXXXXX")
    else
        new_dir=$(mktemp -d "${tmp_base}/tmp.XXXXXX")
    fi

    cd "$new_dir" || return
}

descargar_y_ejecutar() {
    local url="$1"

    if command -v wget >/dev/null 2>&1; then
        wget -O - "$url" | bash
    elif command -v curl >/dev/null 2>&1; then
        curl -fsSL "$url" | bash
    else
        echo "wget or curl not found to download: $url" >&2
        return 1
    fi
}

ejecutar_privilegiado() {
    if [[ $EUID -eq 0 ]]; then
        "$@"
    elif command -v sudo >/dev/null 2>&1; then
        sudo "$@"
    else
        echo "sudo not found and current user is not root; cannot run: $*" >&2
        return 1
    fi
}

detectar_linux_id() {
    os_id=""
    os_like=""

    if [[ -f /etc/os-release ]]; then
        # shellcheck disable=SC1091
        . /etc/os-release
        os_id="${ID,,}"
        os_like="${ID_LIKE,,}"
    fi
}

os_tiene_like() {
    local buscado="$1"

    [[ " ${os_id} ${os_like} " == *" ${buscado} "* ]]
}

seleccionar_herramientas() {
    paquetes=()
    gestor=""

    case "$platform" in
        Darwin)
            if ! command -v brew >/dev/null 2>&1; then
                echo "Homebrew not found; cannot install herrabin tools on macOS." >&2
                return 1
            fi

            gestor="brew"
            paquetes=(
                chafa fzf zoxide ripgrep fd curl git kitty nano zsh python
                bat lsd tldr moreutils grc
            )
            return 0
            ;;
        Linux)
            detectar_linux_id
            ;;
        *)
            echo "Unsupported system for -x: ${platform} ${arch}" >&2
            return 1
            ;;
    esac

    case "$os_id" in
        debian|ubuntu|kali|linuxmint|pop)
            gestor="apt"
            paquetes=(
                sudo chafa fzf zoxide ripgrep fd-find curl git kitty nano
                ifupdown zsh xclip python3 bat lsd tldr iproute2 net-tools
                iputils-ping moreutils grc
            )
            ;;
        arch|manjaro|endeavouros)
            gestor="pacman"
            paquetes=(
                sudo chafa zoxide fzf curl ripgrep fd git kitty nano zsh xclip
                python bat lsd tldr iproute2 net-tools iputils moreutils grc
            )
            ;;
        fedora)
            gestor="dnf"
            paquetes=(
                sudo chafa fzf curl git ripgrep fd-find kitty nano zsh xclip
                python3 bat lsd tldr iproute net-tools iputils moreutils grc
                zoxide
            )
            ;;
        centos|rhel|ol|rocky|almalinux)
            if command -v dnf >/dev/null 2>&1; then
                gestor="dnf"
            else
                gestor="yum"
            fi

            paquetes=(
                sudo chafa fzf curl git ripgrep fd-find kitty nano zsh xclip
                python3 bat lsd tldr iproute net-tools iputils moreutils grc
                zoxide
            )
            ;;
        *)
            if os_tiene_like debian; then
                gestor="apt"
                paquetes=(
                    sudo chafa fzf zoxide ripgrep fd-find curl git kitty nano
                    ifupdown zsh xclip python3 bat lsd tldr iproute2 net-tools
                    iputils-ping moreutils grc
                )
            elif os_tiene_like arch; then
                gestor="pacman"
                paquetes=(
                    sudo chafa zoxide fzf curl ripgrep fd git kitty nano zsh xclip
                    python bat lsd tldr iproute2 net-tools iputils moreutils grc
                )
            elif os_tiene_like fedora || os_tiene_like rhel; then
                if command -v dnf >/dev/null 2>&1; then
                    gestor="dnf"
                else
                    gestor="yum"
                fi

                paquetes=(
                    sudo chafa fzf curl git ripgrep fd-find kitty nano zsh xclip
                    python3 bat lsd tldr iproute net-tools iputils moreutils grc
                    zoxide
                )
            else
                echo "Unsupported Linux distribution for -x: ${os_id:-unknown}" >&2
                return 1
            fi
            ;;
    esac

    case "$gestor" in
        apt|dnf|yum|pacman)
            if ! command -v "$gestor" >/dev/null 2>&1; then
                echo "Package manager not found: ${gestor}" >&2
                return 1
            fi
            ;;
    esac
}

paquete_instalado() {
    local paquete="$1"

    case "$gestor" in
        apt)
            dpkg -s "$paquete" >/dev/null 2>&1
            ;;
        dnf)
            dnf list installed "$paquete" >/dev/null 2>&1
            ;;
        yum)
            yum list installed "$paquete" >/dev/null 2>&1
            ;;
        pacman)
            pacman -Q "$paquete" >/dev/null 2>&1
            ;;
        brew)
            brew list --formula "$paquete" >/dev/null 2>&1
            ;;
        *)
            return 1
            ;;
    esac
}

instalar_paquete() {
    local paquete="$1"

    case "$gestor" in
        apt)
            ejecutar_privilegiado apt install -y "$paquete"
            ;;
        dnf)
            ejecutar_privilegiado dnf install -y "$paquete"
            ;;
        yum)
            ejecutar_privilegiado yum install -y "$paquete"
            ;;
        pacman)
            ejecutar_privilegiado pacman -S --noconfirm "$paquete"
            ;;
        brew)
            brew install "$paquete"
            ;;
        *)
            return 1
            ;;
    esac
}

instalar_herramientas_herrabin() {
    if ! seleccionar_herramientas; then
        return 1
    fi

    echo -e "\n\033[1;34m_________________________________________________________\033[0m\n"
    echo "Installing herrabin base tools with ${gestor}..."

    for paquete in "${paquetes[@]}"; do
        if paquete_instalado "$paquete"; then
            continue
        fi

        echo "Installing package ${paquete}..."
        if ! instalar_paquete "$paquete"; then
            echo -e "${amarillo}Warning: could not install ${paquete}; continuing.${reset}" >&2
        fi
    done
}

# Download and configure binaries
descargar_bina() {
    echo -e "\n\033[1;34m_________________________________________________________\033[0m\n"
    echo "Downloading binaries..."

    # Create temp directory and perform operations
    mktem
    git clone --depth 1 https://github.com/4rji/todo.git
    cd todo || exit 1
    ejecutar_privilegiado mkdir -p "$bin_dir"
    ejecutar_privilegiado cp -a binarios/* "$bin_dir"
    if [[ -f binarios/.todoignore ]]; then
        ejecutar_privilegiado cp -a binarios/.todoignore "$bin_dir"
    fi
    echo ""
    echo -e "\033[1;34mBinaries updated\033[0m"
    cd || exit 1
    echo ""
}

# Remove immutable attributes and delete files in /opt/4rji/bin/*
borrar_archivos() {
    echo -e "${amarillo}Cleaning ${bin_dir}/* ...${reset}"

    # Remove immutable attribute from any files that have it
    ejecutar_privilegiado find "${bin_dir}" -type f -exec chattr -i {} + 2>/dev/null || true

    # Delete files and capture exit code
    if ejecutar_privilegiado rm -rf "${bin_dir:?}"/* 2>/dev/null; then
        echo -e "${verde}Files successfully removed from ${bin_dir}/*${reset}"
        return 0
    else
        echo -e "${amarillo}Warning: Some files could not be removed. Proceeding anyway.${reset}"
        return 0
    fi
}

actualizar_database() {
    if [[ -z "$actualizador" ]]; then
        echo "No updater defined for ${platform} ${arch}."
        return 0
    fi

    if [[ -x "${bin_dir}/${actualizador}" ]]; then
        "${bin_dir}/${actualizador}"
    elif command -v "$actualizador" >/dev/null 2>&1; then
        "$actualizador"
    else
        echo "${actualizador} not found; could not update ~/.todo.txt." >&2
        return 1
    fi
}

# Si se activa la opción -x, instalar herramientas antes de descargar binarios
if [[ $instalarHerramientas == true ]]; then
    instalar_herramientas_herrabin
fi

# Si se activa la opción -c, limpiar primero y luego seguir con flujo normal
if [[ $borrarBinarios == true ]]; then
    borrar_archivos
fi

# Ejecutar descarga de bina si corresponde
if [[ $mostrarBina == true || $borrarBinarios == true || ( $mostrarBina == false && $mostrarPreguntas == false ) ]]; then
    descargar_bina
fi

# Tras -c y descarga de bina, ofrecer ejecutar binariosgo
if [[ $borrarBinarios == true ]]; then
    echo ""
    read -p "$(echo -e ${verde}'Download Go binaries? [Y/n]: '${reset})" -n 1 -r respuesta_go
    echo ""
    respuesta_go=${respuesta_go:-y}
    respuesta_go=$(echo "$respuesta_go" | tr '[:upper:]' '[:lower:]')
    if [[ "$respuesta_go" == "y" ]]; then
        if [[ -x "${bin_dir}/binariosgo" ]]; then
            "${bin_dir}/binariosgo"
        elif command -v binariosgo >/dev/null 2>&1; then
            binariosgo
        else
            echo "binariosgo not found in ${bin_dir} or PATH." >&2
        fi
    else
        echo "Skipped Go binaries."
    fi
fi

# Ejecutar preguntas si corresponde
if [[ $mostrarPreguntas == true || $mostrarBina == true ]]; then
    echo ""
    echo -e "${verde}_________________________________________________________${reset}"
    echo ""

    # Ask user if they want to add the path to PATH
    read -p "Add ${bin_dir} to your PATH? (y/n): " -n 1 -r
    echo    # Move to new line

    # By default, if user presses Enter, consider 'n'
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        # Add binary directory to the modular PATH file.
        zsh_path_file="${ZSH_CONFIG_DIR:-$HOME/.config/zsh}/path.zsh"
        mkdir -p "$(dirname "$zsh_path_file")"
        touch "$zsh_path_file"
        path_line="export PATH=\"\$PATH:${bin_dir}\""
        grep -Fxq "$path_line" "$zsh_path_file" || printf '%s\n' "$path_line" >> "$zsh_path_file"
        echo "Directory ${bin_dir} added to PATH in ${zsh_path_file}."
    else
        echo "No changes made to PATH."
    fi

    echo -e "${azul}"
    echo "_________________________________________________________"
    echo ""

    # Ask user
    read -n1 -p "$(echo -e ${verde}'Install all aliases? (y/N): '${reset})" respuesta
    echo ""

    # Define default value if user presses Enter
    respuesta=${respuesta:-n}

    # Convert response to lowercase
    respuesta=$(echo "$respuesta" | tr '[:upper:]' '[:lower:]')

    # Check response
    if [ "$respuesta" == "y" ]; then
        echo -e "${verde}Installing all aliases... ${reset}"
        if [[ -x "${bin_dir}/herralias" ]]; then
            "${bin_dir}/herralias"
        elif command -v herralias >/dev/null 2>&1; then
            herralias
        else
            echo "herralias not found in ${bin_dir} or PATH." >&2
        fi
    else
        echo ""
    fi

    echo -e "${amarillo}"
    echo "_________________________________________________________"
    echo ""
    echo -e "${amarillo} ########### WARNING  #################${reset}"
    echo ""
    echo -e "${amarillo}This takes a long time to install${reset}"
    echo ""
    echo -e "${amarillo}_________________________________________________________${reset}"
    echo ""

    # Ask user
    read -n1 -p "$(echo -e ${verde}'Install 2-arji? (y/N): '${reset})" respuesta
    echo ""

    # Define default value if user presses Enter
    respuesta=${respuesta:-n}

    # Convert response to lowercase
    respuesta=$(echo "$respuesta" | tr '[:upper:]' '[:lower:]')

    # Check response
    if [ "$respuesta" == "y" ]; then
        descargar_y_ejecutar https://raw.githubusercontent.com/4rji/4rji/main/2-4rji.sh
    else
        echo ""
    fi

fi
actualizar_database
