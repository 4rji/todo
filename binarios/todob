#!/usr/bin/env bash

# Colores
verde='\e[0;32m'
azul='\e[0;34m'
reset='\e[0m'
amarillo='\e[0;33m'

# Variables para controlar el flujo
mostrarPreguntas=false
mostrarBina=false
borrarBinarios=false
bin_dir="/opt/4rji/bin"
platform="$(uname -s)"
arch="$(uname -m)"

case "$platform" in
    Linux)
        tmp_base="/dev/shm"
        actualizador="todou"
        if [[ "$arch" != "x86_64" && "$arch" != "amd64" ]]; then
            echo -e "${amarillo}Non-standard Linux architecture: ${arch}. Included binaries may not be compatible.${reset}"
        fi
        ;;
    Darwin)
        tmp_base="${TMPDIR:-/tmp}"
        actualizador="todoum"
        if [[ "$arch" != "arm64" && "$arch" != "aarch64" ]]; then
            echo -e "${amarillo}Non-standard macOS architecture: ${arch}. Included binaries may not be compatible.${reset}"
        fi
        ;;
    *)
        tmp_base="${TMPDIR:-/tmp}"
        actualizador=""
        echo -e "${amarillo}Unrecognized system: ${platform} ${arch}. Using temp in ${tmp_base}.${reset}"
        ;;
esac

if [[ ! -d "$tmp_base" ]]; then
    tmp_base="/tmp"
fi

# Show script usage
mostrar_uso() {
    echo "Usage: $0 [-p] [-a] [-c]"
    echo "  -p    Show interactive questions only."
    echo "  -a    Run full script (download binaries and show questions)."
    echo "  -c    Clean ${bin_dir}/* then run normal flow (download binaries)."
    exit 1
}

# Verificar las opciones -p, -a y -c
while getopts "pac" opt; do
    case $opt in
        p)
            mostrarPreguntas=true
            ;;
        a)
            mostrarPreguntas=true
            mostrarBina=true
            ;;
        c)
            borrarBinarios=true
            ;;
        \?)
            echo "Invalid option: -$OPTARG" >&2
            mostrar_uso
            ;;
    esac
done

# Shift para manejar correctamente los argumentos
shift $((OPTIND -1))

# Función para crear directorios temporales
mktem() {
    if [ -n "$1" ]; then
        new_dir=$(mktemp -d "${tmp_base}/tmp.$1.XXXXXX")
    else
        new_dir=$(mktemp -d "${tmp_base}/tmp.XXXXXX")
    fi

    cd "$new_dir" || return
}

descargar_y_ejecutar() {
    local url="$1"

    if command -v wget >/dev/null 2>&1; then
        wget -O - "$url" | bash
    elif command -v curl >/dev/null 2>&1; then
        curl -fsSL "$url" | bash
    else
        echo "wget or curl not found to download: $url" >&2
        return 1
    fi
}

# Download and configure binaries
descargar_bina() {
    echo -e "\n\033[1;34m_________________________________________________________\033[0m\n"
    echo "Downloading binaries..."

    # Create temp directory and perform operations
    mktem
    git clone --depth 1 https://github.com/4rji/todo.git
    cd todo || exit 1
    sudo mkdir -p "$bin_dir"
    sudo cp -a binarios/* "$bin_dir"
    if [[ -f binarios/.todoignore ]]; then
        sudo cp -a binarios/.todoignore "$bin_dir"
    fi
    echo ""
    echo -e "\033[1;34mBinaries updated\033[0m"
    cd || exit 1
    echo ""
}

# Remove immutable attributes and delete files in /opt/4rji/bin/*
borrar_archivos() {
    echo -e "${amarillo}Cleaning ${bin_dir}/* ...${reset}"

    # Remove immutable attribute from any files that have it
    sudo find "${bin_dir}" -type f -exec chattr -i {} + 2>/dev/null || true

    # Delete files and capture exit code
    if sudo rm -rf "${bin_dir:?}"/* 2>/dev/null; then
        echo -e "${verde}Files successfully removed from ${bin_dir}/*${reset}"
        return 0
    else
        echo -e "${amarillo}Warning: Some files could not be removed. Proceeding anyway.${reset}"
        return 0
    fi
}

actualizar_database() {
    if [[ -z "$actualizador" ]]; then
        echo "No updater defined for ${platform} ${arch}."
        return 0
    fi

    if [[ -x "${bin_dir}/${actualizador}" ]]; then
        "${bin_dir}/${actualizador}"
    elif command -v "$actualizador" >/dev/null 2>&1; then
        "$actualizador"
    else
        echo "${actualizador} not found; could not update ~/.todo.txt." >&2
        return 1
    fi
}

# Si se activa la opción -c, limpiar primero y luego seguir con flujo normal
if [[ $borrarBinarios == true ]]; then
    borrar_archivos
fi

# Ejecutar descarga de bina si corresponde
if [[ $mostrarBina == true || $borrarBinarios == true || ( $mostrarBina == false && $mostrarPreguntas == false ) ]]; then
    descargar_bina
fi

# Tras -c y descarga de bina, ofrecer ejecutar binariosgo
if [[ $borrarBinarios == true ]]; then
    echo ""
    read -p "$(echo -e ${verde}'Download Go binaries? [Y/n]: '${reset})" -n 1 -r respuesta_go
    echo ""
    respuesta_go=${respuesta_go:-y}
    respuesta_go=$(echo "$respuesta_go" | tr '[:upper:]' '[:lower:]')
    if [[ "$respuesta_go" == "y" ]]; then
        if [[ -x "${bin_dir}/binariosgo" ]]; then
            "${bin_dir}/binariosgo"
        elif command -v binariosgo >/dev/null 2>&1; then
            binariosgo
        else
            echo "binariosgo not found in ${bin_dir} or PATH." >&2
        fi
    else
        echo "Skipped Go binaries."
    fi
fi

# Ejecutar preguntas si corresponde
if [[ $mostrarPreguntas == true || $mostrarBina == true ]]; then
    echo ""
    echo -e "${verde}_________________________________________________________${reset}"
    echo ""

    # Ask user if they want to add the path to PATH
    read -p "Add ${bin_dir} to your PATH? (y/n): " -n 1 -r
    echo    # Move to new line

    # By default, if user presses Enter, consider 'n'
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        # Add binary directory to PATH in ~/.zshrc
        echo "export PATH=\$PATH:${bin_dir}" >> ~/.zshrc
        echo "Directory ${bin_dir} added to PATH in ~/.zshrc."
    else
        echo "No changes made to PATH."
    fi

    echo -e "${azul}"
    echo "_________________________________________________________"
    echo ""

    # Ask user
    read -n1 -p "$(echo -e ${verde}'Install all aliases? (y/N): '${reset})" respuesta
    echo ""

    # Define default value if user presses Enter
    respuesta=${respuesta:-n}

    # Convert response to lowercase
    respuesta=$(echo "$respuesta" | tr '[:upper:]' '[:lower:]')

    # Check response
    if [ "$respuesta" == "y" ]; then
        echo -e "${verde}Installing all aliases... ${reset}"
        descargar_y_ejecutar https://raw.githubusercontent.com/4rji/4rji/main/alias.sh
    else
        echo ""
    fi

    echo -e "${amarillo}"
    echo "_________________________________________________________"
    echo ""
    echo -e "${amarillo} ########### WARNING  #################${reset}"
    echo ""
    echo -e "${amarillo}This takes a long time to install${reset}"
    echo ""
    echo -e "${amarillo}_________________________________________________________${reset}"
    echo ""

    # Ask user
    read -n1 -p "$(echo -e ${verde}'Install 2-arji? (y/N): '${reset})" respuesta
    echo ""

    # Define default value if user presses Enter
    respuesta=${respuesta:-n}

    # Convert response to lowercase
    respuesta=$(echo "$respuesta" | tr '[:upper:]' '[:lower:]')

    # Check response
    if [ "$respuesta" == "y" ]; then
        descargar_y_ejecutar https://raw.githubusercontent.com/4rji/4rji/main/2-4rji.sh
    else
        echo ""
    fi

fi
actualizar_database
